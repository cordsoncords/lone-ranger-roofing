---
const services = [
  { label: 'Roof Replacement',         href: '/residential-roofing/roof-replacement' },
  { label: 'Roof Repair',              href: '/residential-roofing/roof-repair' },
  { label: 'Storm Damage Repair',      href: '/residential-roofing/storm-damage-repair' },
  { label: 'Roof Inspection',          href: '/residential-roofing/roof-inspection' },
  { label: 'Metal Roofing',            href: '/residential-roofing/metal-roofing' },
  { label: 'Asphalt Shingle Roofing',  href: '/residential-roofing/asphalt-shingle-roofing' },
  { label: 'Gutter Installation',      href: '/residential-roofing/gutter-installation' },
  { label: 'Solar',                    href: '/residential-roofing/solar' },
];

const areas = [
  { label: 'Killeen, TX',    href: '/service-areas/killeen' },
  { label: 'Belton, TX',     href: '/service-areas/belton' },
  { label: 'Temple, TX',     href: '/service-areas/temple' },
  { label: 'Salado, TX',     href: '/service-areas/salado' },
  { label: 'Georgetown, TX', href: '/service-areas/georgetown' },
  { label: 'Burnet, TX',     href: '/service-areas/burnet' },
  { label: 'DFW, TX',        href: '/service-areas/dfw' },
];
---

<footer class="bg-brand-900 text-white">
  <!-- Main footer -->
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 text-center md:text-left">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="block">
          <img loading="lazy" decoding="async" src="/logo.webp" alt="Lone Ranger Roofing" class="h-20 w-auto mb-4 mx-auto md:mx-0" />
        </a>
        <p class="text-brand-200 text-sm leading-relaxed mb-4">
          Central Texas' trusted local roofing contractor. Veteran-owned and insured. Most jobs done in a single day.
        </p>
        <div class="flex gap-3 justify-center md:justify-start">
          <a href="https://facebook.com/lonerangerroofing" target="_blank" rel="noopener noreferrer"
             class="bg-brand-800 hover:bg-brand-700 p-3 rounded-lg transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Facebook">
            <svg class="w-4 h-4 fill-white" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://instagram.com/lonerangerroofing" target="_blank" rel="noopener noreferrer"
             class="bg-brand-800 hover:bg-brand-700 p-3 rounded-lg transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Instagram">
            <svg class="w-4 h-4 fill-none stroke-white stroke-2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="white"/>
            </svg>
          </a>
          <a href="https://youtube.com/@lonerangerroofing" target="_blank" rel="noopener noreferrer"
             class="bg-brand-800 hover:bg-brand-700 p-3 rounded-lg transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="YouTube">
            <svg class="w-4 h-4 fill-white" viewBox="0 0 24 24">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="font-bold text-white uppercase tracking-widest text-xs mb-4 text-gold-400">Our Services</h3>
        <ul class="space-y-2">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-brand-200 hover:text-white text-sm transition-colors">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service areas column -->
      <div>
        <h3 class="font-bold text-white uppercase tracking-widest text-xs mb-4 text-gold-400">Service Areas</h3>
        <ul class="space-y-2">
          {areas.map(a => (
            <li>
              <a href={a.href} class="text-brand-200 hover:text-white text-sm transition-colors">
                {a.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact + map column -->
      <div>
        <h3 class="font-bold text-white uppercase tracking-widest text-xs mb-4 text-gold-400">Contact</h3>
        <ul class="space-y-3 text-sm text-brand-200 mb-6">
          <li>
            <a href="tel:+12543001413" class="flex items-start gap-2 hover:text-white transition-colors justify-center md:justify-start">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              (254) 300-1413
            </a>
          </li>
          <li>
            <a href="mailto:info@lonerangerroofing.com" class="flex items-start gap-2 hover:text-white transition-colors justify-center md:justify-start">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              info@lonerangerroofing.com
            </a>
          </li>
          <li class="flex items-start gap-2 justify-center md:justify-start">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            715 E Downs Ave<br/>Temple, TX 76501<br/>Serving Central Texas & DFW
          </li>
          <li class="flex items-start gap-2 justify-center md:justify-start">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Mon–Sat: 8:00am – 6:00pm
          </li>
        </ul>

      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-brand-800 py-6">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-3 text-sm text-brand-300 text-center md:text-left">
      <p>&copy; {new Date().getFullYear()} Lone Ranger Roofing. All Rights Reserved.</p>
      <div class="flex items-center gap-4 justify-center md:justify-start">
        <a href="/refer" class="hover:text-white transition-colors">Refer a Friend</a>
        <span class="text-brand-600">|</span>
        <a href="/sitemap-index.xml" class="hover:text-white transition-colors">Sitemap</a>
        <span class="text-brand-600">|</span>
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <span class="text-brand-600">|</span>
        <a href="/terms" class="hover:text-white transition-colors">Terms</a>
        <span class="text-brand-600">|</span>
        <span>Design by <a href="https://www.mydigitaljuice.com" target="_blank" rel="noopener noreferrer" class="font-bold text-white hover:text-gold-400 transition-colors">Digital Juice</a></span>
      </div>
    </div>
  </div>
</footer>
