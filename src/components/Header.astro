---
const services = [
  { label: 'Roof Replacement',        href: '/residential-roofing/roof-replacement' },
  { label: 'Roof Repair',             href: '/residential-roofing/roof-repair' },
  { label: 'Roof Inspection',         href: '/residential-roofing/roof-inspection' },
  { label: 'Storm Damage Repair',     href: '/residential-roofing/storm-damage-repair' },
  { label: 'Roof Tune Up',            href: '/residential-roofing/roof-tune-up' },
  { label: 'Metal Roofing',           href: '/residential-roofing/metal-roofing' },
  { label: 'Asphalt Shingle Roofing', href: '/residential-roofing/asphalt-shingle-roofing' },
  { label: 'Gutter Installation & Repair', href: '/residential-roofing/gutter-installation' },
  { label: 'Solar',                   href: '/residential-roofing/solar' },
  { label: 'Other Services',          href: '/residential-roofing/other-services' },
];

const commercial = [
  { label: 'TPO Roofing',                href: '/commercial-roofing/tpo-roofing' },
  { label: 'Commercial Metal Roofing',   href: '/commercial-roofing/commercial-metal-roofing' },
  { label: 'Commercial Shingle Roofing', href: '/commercial-roofing/commercial-shingle-roofing' },
];

const areas = [
  { label: 'Killeen',             href: '/service-areas/killeen' },
  { label: 'Belton',              href: '/service-areas/belton' },
  { label: 'Temple',              href: '/service-areas/temple' },
  { label: 'Salado',              href: '/service-areas/salado' },
  { label: 'Georgetown',          href: '/service-areas/georgetown' },
  { label: 'Burnet',              href: '/service-areas/burnet' },
  { label: 'DFW',                 href: '/service-areas/dfw' },
  { label: 'Copperas Cove',       href: '/service-areas/copperas-cove' },
  { label: 'Harker Heights',      href: '/service-areas/harker-heights' },
  { label: 'Nolanville',          href: '/service-areas/nolanville' },
  { label: 'Waco',                href: '/service-areas/waco' },
  { label: 'Gatesville',          href: '/service-areas/gatesville' },
  { label: 'Little River Academy',href: '/service-areas/little-river-academy' },
  { label: 'Moody',               href: '/service-areas/moody' },
  { label: 'Troy',                href: '/service-areas/troy' },
];

const currentPath = Astro.url.pathname;
---

<!-- Sticky wrapper: top bar + nav together -->
<div class="sticky top-0 z-50">


<!-- Main nav -->
<header id="main-nav" class="transition-all duration-300">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-28">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img src="/logo.webp" alt="Lone Ranger Roofing" class="h-32 w-auto object-contain -my-2" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0 text-sm font-semibold">
        <a href="/about" class={`nav-top-link px-2 py-2 rounded-md transition-colors ${currentPath.startsWith('/about') ? 'text-brand-600' : ''}`}>
          About
        </a>

        <!-- Residential Roofing dropdown -->
        <div class="relative nav-dropdown group">
          <button class={`nav-top-link flex items-center gap-1 px-2 py-2 rounded-md transition-colors ${currentPath.startsWith('/services') ? 'text-brand-600' : ''}`}>
            Residential Roofing
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="dropdown-menu hidden absolute left-0 top-full mt-1 w-60 bg-white rounded-xl shadow-xl border border-gray-100 py-2 z-50">
            {services.map(s => (
              <a href={s.href} class="block px-4 py-2.5 text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors text-sm">
                {s.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Commercial Roofing dropdown -->
        <div class="relative nav-dropdown group">
          <button class={`nav-top-link flex items-center gap-1 px-2 py-2 rounded-md transition-colors ${currentPath.startsWith('/commercial-roofing') ? 'text-brand-600' : ''}`}>
            Commercial Roofing
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="dropdown-menu hidden absolute left-0 top-full mt-1 w-64 bg-white rounded-xl shadow-xl border border-gray-100 py-2 z-50">
            {commercial.map(c => (
              <a href={c.href} class="block px-4 py-2.5 text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors text-sm">
                {c.label}
              </a>
            ))}
          </div>
        </div>

        <a href="/gallery" class={`nav-top-link px-2 py-2 rounded-md transition-colors ${currentPath.startsWith('/gallery') ? 'text-brand-600' : ''}`}>
          Gallery
        </a>
        <a href="/roof-a-vet" class={`nav-top-link px-2 py-2 rounded-md transition-colors ${currentPath.startsWith('/roof-a-vet') ? 'text-brand-600' : ''}`}>
          Roof A Vet
        </a>

        <!-- Service Areas dropdown -->
        <div class="relative nav-dropdown group">
          <button class={`nav-top-link flex items-center gap-1 px-2 py-2 rounded-md transition-colors ${currentPath.startsWith('/service-areas') ? 'text-brand-600' : ''}`}>
            Service Areas
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="dropdown-menu hidden absolute left-0 top-full mt-1 w-52 bg-white rounded-xl shadow-xl border border-gray-100 py-2 z-50">
            {areas.map(a => (
              <a href={a.href} class="block px-4 py-2.5 text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors text-sm">
                {a.label}
              </a>
            ))}
          </div>
        </div>
        <a href="/blog" class={`nav-top-link px-2 py-2 rounded-md transition-colors ${currentPath.startsWith('/blog') ? 'text-brand-600' : ''}`}>
          Blog
        </a>
      </nav>

      <!-- Desktop right actions -->
      <div class="hidden lg:flex flex-shrink-0 items-center gap-4">
        <a href="tel:+12543001413" class="font-bold text-gold-400 hover:text-gold-300 transition-colors flex items-center gap-1.5 text-sm whitespace-nowrap">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          (254) 300-1413
        </a>
        <a href="/contact"
           class="bg-accent-600 hover:bg-accent-700 text-white font-bold px-5 py-2.5 rounded-lg transition-colors text-sm uppercase tracking-wide shadow-md whitespace-nowrap">
          Schedule Free Inspection
        </a>
      </div>

      <!-- Mobile: phone + hamburger -->
      <div class="flex lg:hidden items-center gap-3">
        <a href="tel:+12543001413" class="nav-top-link" aria-label="Call us">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </a>
        <button id="mobile-menu-btn" aria-label="Open menu" class="nav-top-link">
          <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <nav class="container mx-auto px-4 py-4 space-y-1 text-sm font-semibold text-gray-700">
      <a href="/about" class="block px-4 py-2.5 rounded-md hover:bg-brand-50 hover:text-brand-700">About</a>

      <div>
        <button class="mobile-accordion-btn flex w-full items-center justify-between px-4 py-2.5 rounded-md hover:bg-brand-50 hover:text-brand-700">
          Residential Roofing
          <svg class="accordion-arrow w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 mt-1 space-y-1">
          {services.map(s => (
            <a href={s.href} class="block px-4 py-2 text-gray-600 hover:text-brand-600 text-sm">{s.label}</a>
          ))}
        </div>
      </div>

      <div>
        <button class="mobile-accordion-btn flex w-full items-center justify-between px-4 py-2.5 rounded-md hover:bg-brand-50 hover:text-brand-700">
          Commercial Roofing
          <svg class="accordion-arrow w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 mt-1 space-y-1">
          {commercial.map(c => (
            <a href={c.href} class="block px-4 py-2 text-gray-600 hover:text-brand-600 text-sm">{c.label}</a>
          ))}
        </div>
      </div>

      <a href="/gallery" class="block px-4 py-2.5 rounded-md hover:bg-brand-50 hover:text-brand-700">Gallery</a>
      <a href="/roof-a-vet" class="block px-4 py-2.5 rounded-md hover:bg-brand-50 hover:text-brand-700">Roof A Vet</a>
      <a href="/blog" class="block px-4 py-2.5 rounded-md hover:bg-brand-50 hover:text-brand-700">Blog</a>

      <div>
        <button class="mobile-accordion-btn flex w-full items-center justify-between px-4 py-2.5 rounded-md hover:bg-brand-50 hover:text-brand-700">
          Service Areas
          <svg class="accordion-arrow w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 mt-1 space-y-1">
          {areas.map(a => (
            <a href={a.href} class="block px-4 py-2 text-gray-600 hover:text-brand-600 text-sm">{a.label}</a>
          ))}
        </div>
      </div>

      <div class="pt-3 border-t border-gray-100">
        <a href="/contact"
           class="block w-full text-center bg-accent-600 hover:bg-accent-700 text-white font-bold px-4 py-3 rounded-lg transition-colors uppercase tracking-wide">
          Schedule Free Inspection
        </a>
        <a href="tel:+12543001413"
           class="block w-full text-center mt-2 border-2 border-brand-900 text-brand-900 font-bold px-4 py-3 rounded-lg hover:bg-brand-50 transition-colors uppercase tracking-wide">
          (254) 300-1413
        </a>
      </div>
    </nav>
  </div>
</header>

</div><!-- end sticky wrapper -->

<style>
  /* Base: transparent with explicit starting color so transition works */
  #main-nav {
    background-color: rgba(0,0,0,0);
    transition: background-color 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
  }

  /* Transparent nav — links are white */
  .nav-top-link { color: white; transition: color 0.4s ease; }
  .nav-top-link:hover { color: #E1B544; }

  /* Scrolled nav — links go dark */
  #main-nav.scrolled .nav-top-link { color: #374151; }
  #main-nav.scrolled .nav-top-link:hover { color: #C73632; }

  /* Scrolled background */
  #main-nav.scrolled { background-color: white; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); border-bottom: 1px solid #f3f4f6; }

  /* Mobile menu always white bg so links stay dark there */
  #mobile-menu .nav-top-link { color: #374151 !important; }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  // Scroll-reveal navbar — transparent only on pages with a dark hero
  const isDarkHero = document.body.dataset.nav === 'dark';
  function updateNav() {
    if (window.scrollY > 10 || !isDarkHero) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-accordion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement;
      const arrow = btn.querySelector('.accordion-arrow') as HTMLElement;
      content?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    });
  });

  // Desktop dropdown — JS-managed hover with 150ms close delay so the
  // mt-1 gap between button and panel never causes the menu to snap shut
  document.querySelectorAll('.nav-dropdown').forEach(wrapper => {
    let closeTimer: ReturnType<typeof setTimeout> | null = null;
    const panel = wrapper.querySelector('.dropdown-menu') as HTMLElement | null;
    if (!panel) return;

    wrapper.addEventListener('mouseenter', () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      panel.classList.remove('hidden');
    });

    wrapper.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(() => { panel.classList.add('hidden'); }, 150);
    });
  });
</script>
