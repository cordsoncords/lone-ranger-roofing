---
const videoId = 'DIG1yaUYgJ8';
const thumbnail = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
const expandedSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1&playsinline=1`;
---

<div id="vw-wrap" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-2">

  <!-- Expanded player (hidden until click) -->
  <div id="vw-player" class="hidden rounded-2xl overflow-hidden shadow-2xl border-2 border-white/20" style="width:min(560px, calc(100vw - 2rem));">
    <div class="relative bg-black" style="aspect-ratio:16/9;">
      <button
        id="vw-close"
        aria-label="Collapse video"
        class="absolute top-2 right-2 z-10 bg-black/60 hover:bg-black/90 text-white rounded-full w-7 h-7 flex items-center justify-center transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <iframe
        id="vw-iframe"
        width="100%"
        height="100%"
        src=""
        data-src={expandedSrc}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
        style="display:block; position:absolute; inset:0; width:100%; height:100%;"
        title="Lone Ranger Roofing"
      ></iframe>
    </div>
  </div>

  <!-- Small thumbnail trigger -->
  <button
    id="vw-trigger"
    aria-label="Watch our story"
    class="group relative rounded-2xl overflow-hidden shadow-xl border-2 border-white/20 hover:border-gold-400 transition-all duration-200 hover:scale-105"
    style="width:min(240px, calc(100vw - 3rem)); height:auto; aspect-ratio:16/9;"
  >
    <!-- Clean thumbnail — no iframe clutter -->
    <img
      src={thumbnail}
      alt="Watch Lone Ranger Roofing"
      class="w-full h-full object-cover"
    />
    <!-- Subtle dark overlay -->
    <div class="absolute inset-0 bg-brand-900/30 group-hover:bg-brand-900/10 transition-colors"></div>
    <!-- Play button -->
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="bg-white/90 group-hover:bg-white rounded-full w-11 h-11 flex items-center justify-center shadow-lg transition-colors">
        <svg class="w-5 h-5 text-accent-600 ml-0.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </div>
    </div>
    <!-- Bottom label -->
    <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/70 to-transparent py-2 px-3">
      <p class="text-white text-[10px] font-bold uppercase tracking-wide text-center">Watch Our Story</p>
    </div>
  </button>

</div>

<script>
  const trigger = document.getElementById('vw-trigger');
  const player  = document.getElementById('vw-player');
  const close   = document.getElementById('vw-close');
  const iframe  = document.getElementById('vw-iframe') as HTMLIFrameElement;

  trigger?.addEventListener('click', () => {
    player?.classList.remove('hidden');
    trigger?.classList.add('hidden');
    if (iframe && !iframe.src) iframe.src = iframe.dataset.src || '';
  });

  close?.addEventListener('click', () => {
    player?.classList.add('hidden');
    trigger?.classList.remove('hidden');
    if (iframe) iframe.src = '';
  });
</script>
