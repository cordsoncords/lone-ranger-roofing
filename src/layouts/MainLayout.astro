---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  darkHero?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.jpg',
  darkHero = false,
} = Astro.props;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "name": "Lone Ranger Roofing",
  "image": "https://lonerangerroofing.com/logo.webp",
  "url": "https://lonerangerroofing.com",
  "telephone": "+12543001413",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "715 E Downs Ave",
    "addressLocality": "Temple",
    "addressRegion": "TX",
    "postalCode": "76501",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 31.1171,
    "longitude": -97.7278
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  ],
  "areaServed": [
    "Killeen, TX", "Belton, TX", "Temple, TX", "Salado, TX",
    "Georgetown, TX", "Burnet, TX", "Dallas-Fort Worth, TX"
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "170"
  },
  "sameAs": [
    "https://www.facebook.com/lonerangerroofing",
    "https://www.instagram.com/lonerangerroofing"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#111140" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/logo.webp" />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2M0VHP1VT5"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2M0VHP1VT5');
    </script>

    <!-- Meta Pixel -->
    <script>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init','1000297108823315');
      fbq('track','PageView');
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
        src="https://www.facebook.com/tr?id=1000297108823315&ev=PageView&noscript=1" />
    </noscript>
  </head>

  <body class="bg-white text-gray-900 antialiased" data-nav={darkHero ? 'dark' : 'light'}>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Sticky Mobile CTA -->
    <div class="fixed bottom-0 left-0 right-0 z-50 lg:hidden border-t border-gray-200 bg-white shadow-[0_-4px_12px_rgba(0,0,0,0.1)]">
      <div class="grid grid-cols-2">
        <a
          href="tel:+12543001413"
          class="flex items-center justify-center gap-2 bg-brand-900 text-white font-bold py-4 text-sm uppercase tracking-wide"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call Now
        </a>
        <a
          href="/contact"
          class="flex items-center justify-center gap-2 bg-accent-600 text-white font-bold py-4 text-sm uppercase tracking-wide"
        >
          Schedule Free Inspection
        </a>
      </div>
    </div>

    <!-- Bottom padding on mobile so sticky CTA doesn't cover content -->
    <div class="h-16 lg:hidden"></div>
  </body>
</html>
