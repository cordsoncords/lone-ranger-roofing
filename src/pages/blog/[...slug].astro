---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const canonicalUrl = `https://lonerangerroofing.com/blog/${post.slug}/`;
const ogImage = post.data.image
  ? `https://lonerangerroofing.com${post.data.image}`
  : 'https://lonerangerroofing.com/og-default.jpg';

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: canonicalUrl,
  author: {
    '@type': 'Organization',
    name: 'Lone Ranger Roofing',
    url: 'https://lonerangerroofing.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Lone Ranger Roofing',
    url: 'https://lonerangerroofing.com',
    logo: { '@type': 'ImageObject', url: 'https://lonerangerroofing.com/logo.webp' },
  },
  image: ogImage,
  ...(post.data.tags && { keywords: post.data.tags.join(', ') }),
};
---

<MainLayout
  darkHero={true}
  title={`${post.data.title} | Lone Ranger Roofing`}
  description={post.data.description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    {post.data.tags && <meta property="article:tag" content={post.data.tags.join(', ')} />}
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <!-- Post header -->
  <section class="bg-brand-900 py-16 text-white -mt-28 pt-44">
    <div class="container mx-auto px-4 max-w-3xl">
      {post.data.tags && post.data.tags.length > 0 && (
        <p class="text-gold-400 text-xs font-bold uppercase tracking-widest mb-3">
          {post.data.tags.join(' · ')}
        </p>
      )}
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-tight mb-4">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-3 text-blue-200 text-sm">
        <span>Lone Ranger Roofing</span>
        <span>·</span>
        <span>{formatDate(post.data.date)}</span>
      </div>
    </div>
  </section>

  {post.data.image && (
    <div class="bg-gray-100">
      <div class="container mx-auto px-4 max-w-3xl">
        <img
          src={post.data.image}
          alt={post.data.title}
          loading="eager"
          fetchpriority="high"
          class="w-full aspect-[16/7] object-cover rounded-b-2xl shadow-lg"
        />
      </div>
    </div>
  )}

  <!-- Post body -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <article class="prose prose-lg max-w-none
        prose-headings:font-black prose-headings:text-brand-900
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-gray-700 prose-p:leading-relaxed
        prose-a:text-accent-600 prose-a:font-semibold prose-a:no-underline hover:prose-a:underline
        prose-strong:text-brand-900
        prose-ul:text-gray-700 prose-li:my-1
        prose-blockquote:border-l-accent-600 prose-blockquote:text-gray-600">
        <Content />
      </article>

      <!-- CTA strip -->
      <div class="mt-12 bg-brand-900 rounded-2xl p-8 text-white text-center">
        <p class="text-gold-400 text-xs font-bold uppercase tracking-widest mb-2">Free Roof Assessment</p>
        <p class="text-xl font-black mb-4">Ready to get eyes on your roof?</p>
        <a href="/contact" class="inline-block bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-3 rounded-lg text-sm uppercase tracking-wide transition-colors mr-3">
          Schedule Inspection
        </a>
        <a href="tel:+12543001413" class="inline-block border border-white/40 hover:border-white text-white font-bold px-8 py-3 rounded-lg text-sm uppercase tracking-wide transition-colors">
          (254) 300-1413
        </a>
      </div>

      <!-- Back link -->
      <div class="mt-10 pt-8 border-t border-gray-100">
        <a href="/blog" class="inline-flex items-center gap-2 text-brand-600 font-bold hover:text-accent-600 transition-colors text-sm uppercase tracking-wide">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to Blog
        </a>
      </div>
    </div>
  </section>
</MainLayout>
