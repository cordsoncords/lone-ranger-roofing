<script>
  const GOLD = '#ECC765';
  const NAVY = '#111140';
  const BLUE = '#AAB0D9';

  function applyStepState(item: Element, active: boolean) {
    const circle = item.querySelector('.step-circle') as HTMLElement | null;
    const label  = item.querySelector('.step-label')  as HTMLElement | null;
    const arrow  = item.querySelector('.step-arrow')  as HTMLElement | null;
    const body   = item.querySelector('.step-item-body');

    (item as HTMLElement).style.borderColor     = active ? GOLD                     : 'rgba(255,255,255,0.15)';
    (item as HTMLElement).style.backgroundColor = active ? 'rgba(255,255,255,0.12)' : 'rgba(255,255,255,0.05)';
    if (circle) { circle.style.backgroundColor = active ? GOLD                     : 'rgba(255,255,255,0.15)';
                  circle.style.color           = active ? NAVY                     : '#ffffff'; }
    if (label)  { label.style.color            = active ? '#ffffff'                : BLUE; }
    if (arrow)  { arrow.style.color            = active ? GOLD                     : 'rgba(255,255,255,0.4)';
                  arrow.style.transform        = active ? 'rotate(180deg)'         : 'rotate(0deg)'; }
    body?.classList.toggle('hidden', !active);
  }

  document.querySelectorAll<HTMLElement>('.step-item').forEach((item, i) => {
    applyStepState(item, i === 0);
  });

  document.querySelectorAll('.step-item-btn').forEach((btn, idx) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.step-item').forEach((item, i) => {
        const isTarget = i === idx;
        applyStepState(item, isTarget);
        item.setAttribute('data-active', isTarget ? 'true' : 'false');
        item.querySelector('.step-item-btn')?.setAttribute('aria-expanded', isTarget ? 'true' : 'false');
      });
    });
  });

  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-item').forEach(el => {
        el.querySelector('.faq-answer')?.classList.add('hidden');
        el.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
        el.querySelector('.faq-icon')?.classList.remove('rotate-180');
      });
      if (!isOpen) {
        answer?.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
