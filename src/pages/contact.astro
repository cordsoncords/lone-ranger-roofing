---
import MainLayout from '../layouts/MainLayout.astro';

const inputClass = "w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent";
const labelClass = "block text-xs font-bold uppercase tracking-wider text-gray-500 mb-2";
---

<MainLayout
  title="Contact Lone Ranger Roofing | Temple, Killeen & Central Texas"
  description="Contact Lone Ranger Roofing for roof repair, replacement, inspections, and storm damage in Temple, Killeen, and Central Texas. Call (254) 300-1413 or fill out our form."
  darkHero={true}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center bg-brand-900 overflow-hidden -mt-28">
    <div class="absolute inset-0">
      <img
        src="/about-hero.webp"
        alt="Lone Ranger Roofing — Contact Us"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900 via-brand-900/85 to-brand-900/30"></div>
    </div>
    <div class="relative z-10 container mx-auto px-4 py-28">
      <div class="max-w-2xl">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4">GET IN TOUCH</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
          Contact Lone Ranger Roofing
        </h1>
        <p class="text-xl text-gray-200 leading-relaxed">
          Serving Temple, Killeen, and Central Texas. Tell us what's going on and we'll get back to you fast.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== CONTACT SECTION ===================== -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <!-- Left: info + map -->
        <div>
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">Reach Us Directly</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-8 leading-tight">
            We're Here When Your Roof Isn't
          </h2>

          <ul class="space-y-5 text-gray-700 mb-10">
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Phone</p>
                <a href="tel:+12543001413" class="text-lg font-black text-brand-900 hover:text-accent-600 transition-colors">(254) 300-1413</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Email</p>
                <a href="mailto:info@lonerangerroofing.com" class="text-brand-900 font-semibold hover:text-accent-600 transition-colors">info@lonerangerroofing.com</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Address</p>
                <p class="text-brand-900 font-semibold leading-snug">715 E Downs Ave<br/>Temple, TX 76501<br/><span class="text-gray-500 font-normal text-sm">Serving Central Texas & DFW</span></p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">Hours</p>
                <p class="text-brand-900 font-semibold">Mon–Sat: 8:00am – 6:00pm</p>
              </div>
            </li>
          </ul>

          <!-- Map -->
          <div class="rounded-xl overflow-hidden border border-gray-200 shadow-lg" style="aspect-ratio:1/1; width:100%; max-width:420px;">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3416.419390991688!2d-97.33402522289269!3d31.098073574410073!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x279f7b5cd7e77991%3A0x53ba1fd7bdc7fcc2!2sLone%20Ranger%20Roofing%2C%20LLC!5e0!3m2!1sen!2sus!4v1778701764986!5m2!1sen!2sus"
              width="100%"
              height="100%"
              style="border:0; display:block; height:100%; min-height:360px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Lone Ranger Roofing location map"
            ></iframe>
          </div>
        </div>

        <!-- Right: contact form -->
        <div class="lg:mt-4">
          <div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100">
            <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-2">Free Estimate</p>
            <h3 class="text-2xl font-black text-brand-900 mb-6">Send Us a Message</h3>
            <form
              action="https://formspree.io/f/mlgyrabo"
              method="POST"
              class="space-y-5"
            >
              <!-- Name row -->
              <div>
                <label class={labelClass}>
                  Name <span class="text-accent-600">(required)</span>
                </label>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <input type="text" name="first_name" placeholder="First Name" required class={inputClass} />
                    <p class="text-[10px] text-gray-400 mt-1">First Name (required)</p>
                  </div>
                  <div>
                    <input type="text" name="last_name" placeholder="Last Name" required class={inputClass} />
                    <p class="text-[10px] text-gray-400 mt-1">Last Name (required)</p>
                  </div>
                </div>
              </div>

              <!-- Phone -->
              <div>
                <label class={labelClass}>Phone <span class="text-accent-600">(required)</span></label>
                <input type="tel" name="phone" placeholder="(___) ___-____" required class={inputClass} />
              </div>

              <!-- Email -->
              <div>
                <label class={labelClass}>Email <span class="text-accent-600">(required)</span></label>
                <input type="email" name="email" placeholder="you@email.com" required class={inputClass} />
              </div>

              <!-- Address -->
              <div>
                <label class={labelClass}>Address <span class="text-accent-600">(required)</span></label>
                <input type="text" name="address" placeholder="123 Main St, Killeen, TX" required class={inputClass} />
              </div>

              <!-- Service needed -->
              <div>
                <label class={labelClass}>Service Needed <span class="text-accent-600">(required)</span></label>
                <select name="service" required class={inputClass + " bg-white"}>
                  <option value="" disabled selected>Select a service…</option>
                  <option value="Roof Repair">Roof Repair</option>
                  <option value="Roof Replacement">Roof Replacement</option>
                  <option value="Storm Damage">Storm Damage</option>
                  <option value="Roof Inspection">Roof Inspection</option>
                  <option value="Gutters">Gutters</option>
                  <option value="Not Sure">Not Sure</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label class={labelClass}>Message <span class="text-accent-600">(required)</span></label>
                <textarea
                  name="message"
                  rows="3"
                  placeholder="Tell us a little more about your situation…"
                  class={inputClass + " resize-none"}
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                class="w-full bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-3.5 rounded-lg text-sm uppercase tracking-wide transition-colors shadow-md"
              >
                Send
              </button>

              <p class="text-[10px] text-gray-400 leading-snug">
                By submitting this form, you authorize Lone Ranger Roofing to contact you via text message regarding your estimate request and project needs. We will never share your personal information with third parties for marketing purposes. Messaging frequency varies based on your project needs. You can opt out at any time by replying STOP. Message and data rates may apply. Consent is not a condition of purchase.{' '}
                <a href="/terms" class="underline hover:text-gray-600">Terms &amp; Conditions</a> | <a href="/privacy-policy" class="underline hover:text-gray-600">Privacy Policy</a>
              </p>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

</MainLayout>
