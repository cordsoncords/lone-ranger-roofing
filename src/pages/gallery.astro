---

<MainLayout
  title="Roofing Project Gallery | Lone Ranger Roofing — Temple, Killeen & DFW"
  description="Browse completed roof replacements and storm damage repairs by Lone Ranger Roofing across Bell County, DFW, and Burnet County. Real projects. Real results."
  darkHero={true}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center bg-brand-900 overflow-hidden -mt-28">
    <div class="absolute inset-0">
      <img
        src="/home-gallery1.webp"
        alt="Completed roofing projects by Lone Ranger Roofing"
        class="w-full h-full object-cover opacity-20"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900 via-brand-900/90 to-brand-900/60"></div>
    </div>
    <div class="relative z-10 container mx-auto px-4 pt-40 pb-32 text-center">
      <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4">Our Work</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
        Roofs We've Replaced Across<br class="hidden sm:block" /> Central Texas and DFW
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Every one of these is a job we walked off of knowing it was done right. Take a look around — then call us about yours.
      </p>
    </div>
  </section>

  <!-- ===================== GALLERY ===================== -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 max-w-7xl">

      <!-- Project grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 items-start" id="gallery-grid">
        {projects.map(project => (
          <div
            class="gallery-card bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 group"
            data-region={project.region}
          >
            <!-- Photo layout: 2 photos side by side -->
            {project.photos.length === 2 && (
              <div class="flex gap-0.5 h-52">
                {project.photos.map((photo, i) => (
                  <button
                    class="lightbox-trigger flex-1 overflow-hidden"
                    data-project={project.id}
                    data-index={i}
                    aria-label={`View photo ${i + 1} of ${project.city} project`}
                  >
                    <img
                      src={photo}
                      alt={`${project.type} in ${project.city}, TX`}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </button>
                ))}
              </div>
            )}
            <!-- Photo layout: 3 photos — main left, 2 stacked right -->
            {project.photos.length === 3 && (
              <div class="flex gap-0.5 h-56">
                <button
                  class="lightbox-trigger w-1/2 overflow-hidden flex-shrink-0"
                  data-project={project.id}
                  data-index={0}
                  aria-label={`View main photo of ${project.city} project`}
                >
                  <img
                    src={project.photos[0]}
                    alt={`${project.type} in ${project.city}, TX`}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </button>
                <div class="w-1/2 flex flex-col gap-0.5">
                  <button
                    class="lightbox-trigger flex-1 overflow-hidden"
                    data-project={project.id}
                    data-index={1}
                    aria-label={`View photo 2 of ${project.city} project`}
                  >
                    <img
                      src={project.photos[1]}
                      alt={`${project.type} in ${project.city}, TX — photo 2`}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </button>
                  <button
                    class="lightbox-trigger flex-1 overflow-hidden"
                    data-project={project.id}
                    data-index={2}
                    aria-label={`View photo 3 of ${project.city} project`}
                  >
                    <img
                      src={project.photos[2]}
                      alt={`${project.type} in ${project.city}, TX — photo 3`}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </button>
                </div>
              </div>
            )}

            <!-- Card footer -->
            <div class="px-5 py-5">
              <p class="font-black text-brand-900 text-sm">{project.city}, TX</p>
              <p class="text-accent-600 text-xs font-bold uppercase tracking-wide mt-0.5 mb-3">{project.type}</p>
              <p class="text-gray-600 text-sm leading-relaxed">{project.description}</p>
            </div>
