                { city: 'Burnet',                href: '/service-areas/burnet' },
                { city: 'Harker Heights',        href: '/service-areas/harker-heights' },
                { city: 'Nolanville',            href: '/service-areas/nolanville' },
                { city: 'Copperas Cove',         href: '/service-areas/copperas-cove' },
                { city: 'Waco',                  href: '/service-areas/waco' },
                { city: 'Gatesville',            href: '/service-areas/gatesville' },
                { city: 'Little River Academy',  href: '/service-areas/little-river-academy' },
