---
import MainLayout from '../layouts/MainLayout.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.tsx';
import PreFooterCTA from '../components/PreFooterCTA.astro';

const services = [
  {
    title: 'Roof Replacement',
    desc: 'Full tear-off and install, most jobs done in one day.',
    href: '/residential-roofing/roof-replacement',
    img: '/home-roof-replacement.webp',
  },
  {
    title: 'Storm Damage Repair',
    desc: 'Hail, wind, debris — we assess, document, and fix it fast.',
    href: '/residential-roofing/storm-damage-repair',
    img: '/home-storm-damage-repair.webp',
  },
  {
    title: 'Roof Repair',
    desc: 'Stop leaks at the root cause, not just the symptom.',
    href: '/residential-roofing/roof-repair',
    img: '/home-repair.webp',
  },
  {
    title: 'Roof Inspection',
    desc: 'Free post-storm inspections. Honest findings. No pressure.',
    href: '/residential-roofing/roof-inspection',
    img: '/home-inspection.webp',
  },
  {
    title: 'Metal Roofing',
    desc: 'Built for Central Texas weather. Lasts 40–70 years.',
    href: '/residential-roofing/metal-roofing',
    img: '/gallery5.webp',
  },
  {
    title: 'Gutter Installation & Repair',
    desc: 'Protect your foundation, siding, and landscaping.',
    href: '/residential-roofing/gutter-installation',
    img: '/gallery6.webp',
  },
];

const stats = [
  { number: '200+',    label: 'Google Reviews' },
  { number: '1 Day',   label: 'Most Completions' },
  { number: '40-Year', label: 'Workmanship Warranty' },
  { number: 'Free',    label: 'Roof Assessment' },
];

const whyPoints = [
  { title: 'One-Day Completion',          desc: 'Most replacements done in a day. No three-week job sitting half-finished on your roof.' },
  { title: 'Labor AND Material Warranty', desc: "Most roofers only warranty the shingles. We warranty our work too, because that's usually where the problems start." },
  { title: 'Insurance Claim Experts',     desc: "We've walked hundreds of Central Texas homeowners through claims. We know what adjusters look for, and we look for it first." },
  { title: 'Veteran-Owned',              desc: 'Built on the same standard Julio held in the Army: show up, do it right, own it.' },
];

const areas = [
  { city: 'Killeen',    state: 'TX', href: '/service-areas/killeen' },
  { city: 'Temple',     state: 'TX', href: '/service-areas/temple' },
  { city: 'Belton',     state: 'TX', href: '/service-areas/belton' },
  { city: 'Salado',     state: 'TX', href: '/service-areas/salado' },
  { city: 'Georgetown', state: 'TX', href: '/service-areas/georgetown' },
  { city: 'Burnet',     state: 'TX', href: '/service-areas/burnet' },
  { city: 'DFW',        state: 'TX', href: '/service-areas/dfw' },
];
---

<MainLayout
  title="Lone Ranger Roofing | Central Texas Roofing Contractor | (254) 300-1413"
  description="Lone Ranger Roofing serves Killeen, Temple, Belton, Salado, Georgetown, Burnet, and DFW with roof replacements, storm damage repair, inspections, and gutters. Veteran-owned. Most jobs done in one day."
  darkHero={true}
  preloadImage="/home-roof-replacement.webp"
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center overflow-hidden bg-brand-900 -mt-28">
    <!-- Video background (fallback to image if video not loaded) -->
    <div class="absolute inset-0 z-0">
      <video
        id="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="/home-roof-replacement.webp"
        fetchpriority="high"
        class="w-full h-full object-cover object-center"
      ></video>
      <div class="absolute inset-0 bg-brand-900/65"></div>
    </div>

    <script>
      // Load hero video after page is interactive so it doesn't block LCP
      window.addEventListener('load', () => {
        const v = document.getElementById('hero-video') as HTMLVideoElement | null;
        if (!v) return;
        const src = document.createElement('source');
        src.src = '/hero-video.mp4';
        src.type = 'video/mp4';
        v.appendChild(src);
        v.load();
        v.play().catch(() => {});
      });
    </script>

    <div class="relative z-10 container mx-auto px-4 pt-36 pb-12 lg:pt-32 lg:pb-16 text-center">
      <div class="max-w-3xl mx-auto">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4 flex items-center justify-center gap-2">
          <span class="w-6 h-0.5 bg-gold-400 inline-block"></span>
          VETERAN-OWNED ROOFING IN TEMPLE, KILLEEN & CENTRAL TEXAS
          <span class="w-6 h-0.5 bg-gold-400 inline-block"></span>
        </p>

        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl leading-none text-white mb-6">
          Roof in Danger?<br />
          <span class="text-gold-400">Call Lone Ranger.</span>
        </h1>

        <p class="text-lg text-gray-200 mb-8 max-w-2xl mx-auto leading-relaxed">
          Storm hits. Your roof takes damage. Suddenly you're dealing with insurance companies and
          contractors who may or may not have your back. Lone Ranger Roofing is the veteran-owned
          team that actually does.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-10 justify-center">
          <a href="/contact"
             class="inline-flex items-center justify-center gap-2 bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-4 rounded-lg text-base uppercase tracking-wide transition-colors shadow-xl">
            Schedule Free Inspection
          </a>
          <a href="tel:+12543001413"
             class="inline-flex items-center justify-center gap-2 border-2 border-gold-400 text-gold-400 hover:bg-gold-400 hover:text-brand-900 font-black px-8 py-4 rounded-lg text-base uppercase tracking-wide transition-colors">
            Call (254) 300-1413
          </a>
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-300 font-medium justify-center">
          {[
            ['M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z', 'Veteran-Owned'],
            ['M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', 'Local'],
            ['M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z', '5-Star Rated'],
          ].map(([path, label]) => (
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={path}/>
              </svg>
              {label}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STATS ===================== -->
  <section class="py-12 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-gray-200 anim-stagger">
        {stats.map(s => (
          <div class="text-center px-4 py-4 anim-fade-up">
            <p class="text-4xl lg:text-5xl font-black text-brand-900 leading-none">{s.number}</p>
            <p class="text-sm text-gray-500 font-medium mt-1.5 uppercase tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== WHY THE COMMUNITY CHOOSES LONE RANGER ===================== -->
  <section class="py-20 bg-gray-50 overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-16">

        <!-- Left: image stack -->
        <div class="w-full lg:w-5/12 relative flex-shrink-0 anim-fade-left">
          <img
            src="/home-about.webp"
            alt="Lone Ranger Roofing crew completing a Central Texas job"
            width="1400" height="725"
            loading="lazy" decoding="async"
            class="rounded-2xl shadow-2xl w-full object-cover"
          />
          <!-- Floating review badge -->
          <div class="absolute -top-5 -left-5 bg-white rounded-2xl px-5 py-3 shadow-xl border border-gray-100 flex items-center gap-3">
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(i => (
                <svg class="w-4 h-4 fill-gold-400" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <div>
              <p class="text-xs font-black text-brand-900 leading-none">200+</p>
              <p class="text-[10px] text-gray-500 leading-none mt-0.5">5-Star Reviews</p>
            </div>
          </div>
        </div>

        <!-- Right: copy -->
        <div class="w-full lg:w-7/12">
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">ABOUT US</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-4 leading-tight">
            Why Central Texas Chooses<br />Lone Ranger Roofing
          </h2>
          <p class="text-gray-600 leading-relaxed mb-3">
            Working with Lone Ranger Roofing is like pulling up to a drive-through window and finding out the person in front of you paid for your meal. You get the warm fuzzies, sure — but more than that, you get peace of mind.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            We're a local roofing contractor serving Bell County, Burnet County, McLennan County, and the DFW area. We treat customers like family. We value service above everything else. And we deliver quality roofing every single time. Here's the promise behind Lone Ranger Roofing: When your roof is on the line, we're on your side. Rest assured, if your roof is in danger, just call the Lone Ranger.
          </p>

          <div class="grid sm:grid-cols-2 gap-5 mb-8">
            {whyPoints.map(p => (
              <div class="flex items-start gap-3">
                <div class="bg-accent-600 rounded-lg p-1.5 flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-brand-900 text-sm">{p.title}</p>
                  <p class="text-gray-500 text-sm leading-relaxed mt-0.5">{p.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/about"
               class="inline-flex items-center justify-center border-2 border-brand-900 text-brand-900 hover:bg-brand-900 hover:text-white font-bold px-7 py-3.5 rounded-lg text-sm uppercase tracking-wide transition-colors">
              Learn More About Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== BADGES / MEMBERSHIPS ===================== -->
  <section class="py-10 bg-white border-b border-gray-100 overflow-hidden">
    <p class="text-center text-xs font-bold uppercase tracking-widest text-gray-600 mb-8">
      Proud Members &amp; Certified By
    </p>
    <div class="marquee-track">
      <div class="marquee-inner">
        {[
          { src: '/taba-badge.webp',    alt: 'TABA Member',                  h: 'h-20', w: 292, nh: 107 },
          { src: '/belton-badge.webp',  alt: 'Belton Chamber of Commerce',   h: 'h-16', w: 245, nh: 122 },
          { src: '/salado-badge.webp',  alt: 'Salado Chamber of Commerce',   h: 'h-16', w: 226, nh: 172 },
          { src: '/killeen-badge.webp', alt: 'Killeen Chamber of Commerce',  h: 'h-16', w: 790, nh: 316 },
          { src: '/tba-badge.webp',     alt: 'Temple Business Association',  h: 'h-16', w: 1024, nh: 559 },
          { src: '/taba-badge.webp',    alt: 'TABA Member',                  h: 'h-20', w: 292, nh: 107 },
          { src: '/belton-badge.webp',  alt: 'Belton Chamber of Commerce',   h: 'h-16', w: 245, nh: 122 },
          { src: '/salado-badge.webp',  alt: 'Salado Chamber of Commerce',   h: 'h-16', w: 226, nh: 172 },
          { src: '/killeen-badge.webp', alt: 'Killeen Chamber of Commerce',  h: 'h-16', w: 790, nh: 316 },
          { src: '/tba-badge.webp',     alt: 'Temple Business Association',  h: 'h-16', w: 1024, nh: 559 },
        ].map(b => (
          <img loading="lazy" decoding="async" src={b.src} alt={b.alt} width={b.w} height={b.nh} class={`${b.h} w-auto object-contain flex-shrink-0`} />
        ))}
      </div>
    </div>
  </section>

  <style>
    .marquee-track {
      display: flex;
      width: 100%;
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    }
    .marquee-inner {
      display: flex;
      align-items: center;
      gap: 80px;
      padding: 0 40px;
      animation: marquee-scroll 18s linear infinite;
      white-space: nowrap;
    }
    @keyframes marquee-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .marquee-inner:hover { animation-play-state: paused; }
  .city-scroll {
    scrollbar-width: thin;
    scrollbar-color: #C73632 transparent;
    direction: rtl;
  }
  .city-scroll > * {
    direction: ltr;
  }
  .city-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .city-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .city-scroll::-webkit-scrollbar-thumb {
    background-color: #C73632;
    border-radius: 9999px;
  }
  </style>

  <!-- ===================== SERVICES (IMAGE CARDS) ===================== -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">OUR SERVICES</p>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-4">
          Roof Replacement, Repair & Storm Restoration Services
        </h2>
        <p class="text-gray-500 text-lg max-w-3xl mx-auto">
          From a single missing shingle to a full storm replacement — we handle it. Veteran-owned, insured, and most jobs done in a single day with a warranty that covers both materials and our work.
        </p>
      </div>

      <!-- Bento grid: alternating large/small cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

        <!-- Row 1: large (2/3) + small (1/3) -->
        <div class="group relative sm:col-span-2 aspect-[16/9] anim-fade-up">
          <!-- Card (overflow-hidden kept inside so badge can hang off) -->
          <div class="absolute inset-0 rounded-2xl overflow-hidden shadow-md">
            <img loading="lazy" decoding="async" src={services[0].img} alt={services[0].title}
                 class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"/>
            <div class="absolute inset-0 bg-gradient-to-t from-brand-900 via-brand-900/40 to-transparent"></div>
            <div class="absolute inset-0 flex flex-col justify-end p-7">
              <h3 class="text-2xl font-black text-white mb-1">{services[0].title}</h3>
              <p class="text-sm text-gray-300 mb-4 leading-snug max-w-sm">{services[0].desc}</p>
              <div class="flex gap-2">
                <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-bold py-2 px-4 rounded-lg text-xs uppercase tracking-wide transition-colors">Schedule Free Inspection</a>
                <a href={services[0].href} class="border border-white/60 hover:border-white text-white font-bold py-2 px-4 rounded-lg text-xs uppercase tracking-wide transition-colors hover:bg-white/10">Learn More<span class="sr-only"> about {services[0].title}</span></a>
              </div>
            </div>
          </div>
          <!-- IKO badge hanging off top-left corner -->
          <div class="hidden sm:block absolute -top-5 -left-5 z-10 bg-white rounded-2xl p-2 shadow-xl border border-gray-100">
            <img loading="lazy" decoding="async" src="/iko-badge.webp" alt="IKO Craftsman Premier" width="235" height="235" class="h-40 w-auto object-contain" />
          </div>
        </div>

        <div class="group relative sm:col-span-1 rounded-2xl overflow-hidden aspect-[4/3] sm:aspect-auto shadow-md">
          <img loading="lazy" decoding="async" src={services[1].img} alt={services[1].title}
               class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"/>
          <div class="absolute inset-0 bg-gradient-to-t from-brand-900 via-brand-900/50 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-5">
            <h3 class="text-lg font-black text-white mb-1">{services[1].title}</h3>
            <p class="text-xs text-gray-300 mb-3 leading-snug">{services[1].desc}</p>
            <div class="flex gap-2">
              <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-bold py-1.5 px-3 rounded-lg text-xs uppercase tracking-wide transition-colors">Book</a>
              <a href={services[1].href} class="border border-white/60 hover:border-white text-white font-bold py-1.5 px-3 rounded-lg text-xs uppercase tracking-wide transition-colors hover:bg-white/10">Learn More<span class="sr-only"> about {services[1].title}</span></a>
            </div>
          </div>
        </div>

        <!-- Row 2: small (1/3) + large (2/3) -->
        <div class="group relative sm:col-span-1 rounded-2xl overflow-hidden aspect-[4/3] sm:aspect-auto shadow-md">
          <img loading="lazy" decoding="async" src={services[2].img} alt={services[2].title}
               class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"/>
          <div class="absolute inset-0 bg-gradient-to-t from-brand-900 via-brand-900/50 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-5">
            <h3 class="text-lg font-black text-white mb-1">{services[2].title}</h3>
            <p class="text-xs text-gray-300 mb-3 leading-snug">{services[2].desc}</p>
            <div class="flex gap-2">
              <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-bold py-1.5 px-3 rounded-lg text-xs uppercase tracking-wide transition-colors">Book</a>
              <a href={services[2].href} class="border border-white/60 hover:border-white text-white font-bold py-1.5 px-3 rounded-lg text-xs uppercase tracking-wide transition-colors hover:bg-white/10">Learn More<span class="sr-only"> about {services[2].title}</span></a>
            </div>
          </div>
        </div>

        <div class="group relative sm:col-span-2 rounded-2xl overflow-hidden aspect-[16/9] shadow-md">
          <img loading="lazy" decoding="async" src={services[3].img} alt={services[3].title}
               class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"/>
          <div class="absolute inset-0 bg-gradient-to-t from-brand-900 via-brand-900/40 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-7">
            <h3 class="text-2xl font-black text-white mb-1">{services[3].title}</h3>
            <p class="text-sm text-gray-300 mb-4 leading-snug max-w-sm">{services[3].desc}</p>
            <div class="flex gap-2">
              <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-bold py-2 px-4 rounded-lg text-xs uppercase tracking-wide transition-colors">Schedule Free Inspection</a>
              <a href={services[3].href} class="border border-white/60 hover:border-white text-white font-bold py-2 px-4 rounded-lg text-xs uppercase tracking-wide transition-colors hover:bg-white/10">Learn More<span class="sr-only"> about {services[3].title}</span></a>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- ===================== FLEXIBLE FINANCING ===================== -->
  <section class="py-20 bg-brand-900 text-white">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-16">

        <!-- Left: copy -->
        <div class="w-full lg:w-1/2">
          <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-3">FINANCING OPTIONS</p>
          <h2 class="text-3xl sm:text-4xl font-black mb-4 leading-tight">
            Flexible Roof Financing Options<br />for Every Budget
          </h2>
          <p class="text-brand-200 leading-relaxed mb-3">
            We get it. Roof replacement is an investment. But here's what Lone Ranger Roofing knows:
            putting off repairs or replacements always costs more. What started as a $5,000 fix turns
            into $15,000 in water damage. What seemed manageable becomes a disaster.
          </p>
          <p class="text-brand-200 leading-relaxed mb-8">
            That's why Lone Ranger Roofing partnered with Hearth to offer flexible roof financing
            options. No matter what your budget looks like right now, we can work out an affordable
            roofing plan that lets you protect your home without wrecking your wallet. Your roof is
            your biggest asset. It deserves to be protected.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contact"
               class="inline-flex items-center justify-center bg-gold-400 hover:bg-gold-500 text-brand-900 font-black px-7 py-3.5 rounded-lg text-sm uppercase tracking-wide transition-colors shadow-md">
              Schedule Free Inspection
            </a>
            <a href="tel:+12543001413"
               class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white text-white font-bold px-7 py-3.5 rounded-lg text-sm uppercase tracking-wide transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              (254) 300-1413
            </a>
          </div>
        </div>

        <!-- Right: feature card stack -->
