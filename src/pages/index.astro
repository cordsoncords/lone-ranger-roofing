  <script>
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const arrow = btn.querySelector('.faq-arrow') as HTMLElement;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all others
        document.querySelectorAll('.faq-btn').forEach(other => {
          if (other !== btn) {
            other.setAttribute('aria-expanded', 'false');
            (other.nextElementSibling as HTMLElement)?.classList.add('hidden');
            (other.querySelector('.faq-arrow') as HTMLElement)?.classList.remove('rotate-180');
          }
        });

        // Toggle this one
        btn.setAttribute('aria-expanded', String(!isOpen));
        answer?.classList.toggle('hidden', isOpen);
        arrow?.classList.toggle('rotate-180', !isOpen);
      });
    });
  </script>

