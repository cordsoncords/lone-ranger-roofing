---
import MainLayout from '../../layouts/MainLayout.astro';
import PreFooterCTA from '../../components/PreFooterCTA.astro';

const faqs = [
  {
    q: 'What types of gutters does Lone Ranger Roofing install?',
    a: 'Lone Ranger Roofing installs both seamless and sectional gutter systems for homeowners across Temple, Killeen, Harker Heights, Belton, Georgetown, and throughout DFW. We work with aluminum and other available materials and help homeowners choose the right system for their home, roof line, and drainage needs.',
  },
  {
    q: "What's the difference between seamless and sectional gutters?",
    a: 'Seamless gutters are cut from a single continuous piece of material and custom-fit to your home on-site — no seams means far fewer leak points and better long-term performance. Sectional gutters come in pre-cut pieces joined with seams that can eventually leak or separate. For most homeowners in Central Texas and DFW, Lone Ranger Roofing recommends seamless gutters for superior durability and appearance.',
  },
  {
    q: 'Does Lone Ranger Roofing repair gutters or only replace them?',
    a: 'Lone Ranger Roofing repairs gutters first when repair is the right solution. We don\'t believe in pushing replacement on gutters that can be fixed. After a thorough assessment of your gutter system across Temple, Killeen, Belton, or anywhere in Central Texas, we\'ll give you an honest recommendation on whether repair or replacement makes more sense.',
  },
  {
    q: 'Does Lone Ranger Roofing install gutter guards?',
    a: 'Yes. Lone Ranger Roofing installs gutter guard systems for homeowners across Central Texas and DFW. Gutter guards keep leaves, debris, and shingle grit out of your gutters so they stay clear and flowing without constant cleaning — especially valuable in areas with heavy tree cover.',
  },
  {
    q: 'How long do seamless gutters last in Central Texas?',
    a: 'Seamless aluminum gutters installed by Lone Ranger Roofing in Temple, Killeen, and across Central Texas typically last 20-25 years with proper maintenance. Texas weather can shorten that lifespan if gutters are neglected, so periodic inspections and cleaning are recommended to maintain performance.',
  },
  {
    q: 'Should I replace my gutters when I replace my roof?',
    a: 'It often makes sense to replace aging gutters at the same time as a roof replacement. Lone Ranger Roofing handles both roofing and gutter installation across Temple, Killeen, and Central Texas — one contractor, one project, and gutters properly sized and installed to work with your new roof\'s drainage needs.',
  },
];

const gutterServices = [
  {
    title: 'Seamless Gutter Installation',
    body: 'Seamless gutters are cut from a single piece of material on-site and custom-fit to your home. No seams means no joints to leak, pull apart, or collect debris. The superior option for most Central Texas homes.',
