---
import MainLayout from '../../layouts/MainLayout.astro';
import PreFooterCTA from '../../components/PreFooterCTA.astro';

const services = [
  {
    title: 'Fencing',
    photo: '/fence.webp',
    body: 'Storm-damaged or worn-out fencing? We repair and replace it across Central Texas and DFW.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>`,
  },
  {
    title: 'Exterior Painting',
    photo: '/painting.webp',
    body: 'Professional exterior painting with premium paints built to hold up to Texas weather.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
  },
  {
    title: 'Siding',
    photo: '/siding.webp',
    body: 'Hail, wind, or age damage to your siding? We install and replace it — often in the same project as your roof.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  },
  {
    title: 'Garage Doors',
    photo: '/garage.webp',
    body: 'Storm or hail took out your garage door? We install and replace them across Central Texas and DFW.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>`,
  },
];
---

<MainLayout
  title="Fencing, Painting, Siding & Garage Doors in Central Texas | Lone Ranger Roofing"
  description="Lone Ranger Roofing handles more than roofs. Fencing, exterior painting, siding, and garage doors for homeowners across Central Texas and DFW. Full service exterior contractor."
  darkHero={true}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center bg-brand-900 overflow-hidden -mt-28">
    <div class="absolute inset-0">
      <img
        src="/home-about.webp"
        alt="Full exterior services — Central Texas and DFW"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900 via-brand-900/85 to-brand-900/30"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 py-28">
      <div class="max-w-2xl">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4">Other Services</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
          Fencing, Painting, Siding &amp; Garage Doors in Temple, Killeen &amp; Belton
        </h1>
        <p class="text-xl text-gray-200 leading-relaxed mb-8">
          You know us for roofs. But if any part of your home's exterior needs attention, Lone Ranger has you covered — across all of Bell County, Burnet County, Waco, and DFW.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="tel:+12543001413" class="bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center shadow-lg">
            Call (254) 300-1413
          </a>
          <a href="/contact" class="border-2 border-white/50 hover:border-white text-white font-bold px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center hover:bg-white/10">
            Schedule Free Consultation
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== INTRO ===================== -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">

        <!-- Photo side -->
        <div class="relative order-2 lg:order-1">
          <img src="/race.webp" alt="Lone Ranger Roofing — full exterior services" class="w-full h-[480px] object-cover rounded-2xl shadow-xl" />
        </div>

        <!-- Text side -->
        <div class="order-1 lg:order-2">
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">THE FULL PICTURE</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-6">
            Racing to Take Care of Your Whole Home
          </h2>
          <p class="text-gray-600 leading-relaxed mb-8">
            Our clients kept asking us to handle more than the roof — and that made sense. When a hailstorm hits Bell County, it doesn't just damage shingles. It damages siding, fencing, gutters, and everything else on the exterior. Lone Ranger Roofing expanded to handle fencing, exterior painting, siding, and garage doors so homeowners in Temple, Killeen, Harker Heights, Belton, and across Central Texas and DFW can make one call instead of four. Same veteran-owned standard. Same honest approach. Just a bigger scope.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-gray-200 border border-gray-200 rounded-2xl overflow-hidden text-center">
            {[
              { stat: 'One Call', label: 'For the Whole Exterior' },
              { stat: 'Veteran-Owned', label: 'Same Standard, Every Service' },
              { stat: 'Central Texas', label: 'Based, Not Storm-Chasing' },
            ].map(item => (
              <div class="py-6 px-3">
                <div class="w-8 h-0.5 bg-accent-600 mx-auto mb-3"></div>
                <p class="text-brand-900 font-black text-base leading-none mb-1">{item.stat}</p>
                <p class="text-gray-500 text-xs leading-snug">{item.label}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== SERVICES CAROUSEL ===================== -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-10">
        <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">OTHER SERVICES</p>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-900">
          What Else We Handle for Central Texas Homeowners
        </h2>
      </div>

      <!-- Carousel wrapper -->
      <div id="svc-carousel" class="relative select-none">
        <!-- Cards -->
        <div id="svc-track" class="overflow-hidden">
          {services.map((service, i) => (
            <div
              class={`svc-slide bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden ${i === 0 ? '' : 'hidden'}`}
              data-index={i}
            >
              <!-- Photo -->
              <div class="w-full overflow-hidden" style="aspect-ratio:16/9;">
                <img src={service.photo} alt={`${service.title} — Lone Ranger Roofing`} class="w-full h-full object-cover" />
              </div>
              <!-- Content -->
              <div class="px-8 py-7 flex flex-col gap-3">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center flex-shrink-0 [&>svg]:w-5 [&>svg]:h-5" set:html={service.icon} />
                  <h3 class="font-black text-brand-900 text-2xl leading-tight">{service.title}</h3>
                </div>
                <p class="text-gray-600 leading-relaxed">{service.body}</p>
                <a href="tel:+12543001413" class="text-accent-600 font-bold text-sm uppercase tracking-wide flex items-center gap-1.5">
                  Call (254) 300-1413 for a Free Estimate
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Controls row: prev · dots · next -->
        <div class="flex items-center justify-center gap-6 mt-6">
          <button id="svc-prev" aria-label="Previous service"
            class="w-11 h-11 rounded-full bg-white border border-gray-200 shadow-sm flex items-center justify-center hover:border-accent-600 hover:text-accent-600 transition-colors text-gray-500">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>

          <div id="svc-dots" class="flex items-center gap-2">
            {services.map((_, i) => (
              <button
                class={`svc-dot transition-all rounded-full ${i === 0 ? 'w-6 h-2.5 bg-accent-600' : 'w-2.5 h-2.5 bg-gray-300 hover:bg-gray-400'}`}
                data-index={i}
                aria-label={`Go to service ${i + 1}`}
              ></button>
            ))}
          </div>

          <button id="svc-next" aria-label="Next service"
            class="w-11 h-11 rounded-full bg-white border border-gray-200 shadow-sm flex items-center justify-center hover:border-accent-600 hover:text-accent-600 transition-colors text-gray-500">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    (() => {
      const slides = Array.from(document.querySelectorAll<HTMLElement>('.svc-slide'));
      const dots   = Array.from(document.querySelectorAll<HTMLElement>('.svc-dot'));
      let current  = 0;

      function goTo(n: number) {
        slides[current].classList.add('hidden');
        dots[current].classList.remove('w-6', 'h-2.5', 'bg-accent-600');
        dots[current].classList.add('w-2.5', 'h-2.5', 'bg-gray-300');

        current = (n + slides.length) % slides.length;

        slides[current].classList.remove('hidden');
        dots[current].classList.remove('w-2.5', 'h-2.5', 'bg-gray-300');
        dots[current].classList.add('w-6', 'h-2.5', 'bg-accent-600');
      }

      document.getElementById('svc-prev')?.addEventListener('click', () => goTo(current - 1));
      document.getElementById('svc-next')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

      // Touch/swipe support
      const track = document.getElementById('svc-track');
      if (track) {
        let startX = 0;
        track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
        track.addEventListener('touchend', (e) => {
          const dx = e.changedTouches[0].clientX - startX;
          if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
        }, { passive: true });
      }
    })();
  </script>

  <!-- ===================== GALLERY STRIP ===================== -->
  <div class="grid grid-cols-3 md:grid-cols-6 h-48">
    {[
      '/home-gallery1.webp',
      '/home-gallery2.webp',
      '/home-gallery3.webp',
      '/home-gallery4.webp',
      '/home-gallery5.webp',
      '/home-gallery6.webp',
    ].map((src, i) => (
      <div class="relative overflow-hidden group">
        <img
          src={src}
          alt={`Lone Ranger Roofing exterior project ${i + 1} — Central Texas`}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-brand-900/30 group-hover:bg-brand-900/0 transition-colors duration-300"></div>
      </div>
    ))}
  </div>

  <!-- ===================== TRUST SECTION ===================== -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">WHY HOMEOWNERS TRUST US</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-4">One Guy. Every Tool. Every Job.</h2>
          <p class="text-gray-600 leading-relaxed max-w-2xl mx-auto">Roofing, fencing, painting, siding, garage doors — Julio doesn't hand you off to a subcontractor for the stuff that's not "roofing." He's built Lone Ranger to handle it all, the same way, every time.</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Photo -->
          <div class="relative">
            <img src="/swiss.webp" alt="Julio Rojas — Lone Ranger Roofing" class="w-full h-[480px] object-cover rounded-2xl shadow-xl" />
          </div>

          <!-- Trust items -->
          <div class="flex flex-col gap-8">
            {[
              {
                title: 'One Contractor',
                body: 'Roofing, fencing, painting, siding, garage doors. One call, one crew, one standard.',
                icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
              },
              {
                title: 'Veteran-Owned',
                body: 'Julio served as an Army Ranger. Every exterior service holds the same standard.',
                icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
              },
              {
                title: 'Insurance Claim Ready',
                body: 'When a storm hits, we document all exterior damage — not just the roof — for your claim.',
                icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
              },
              {
                title: 'Honest Recommendations',
                body: "If something doesn't need replacement, we'll tell you. We're not here to generate work that doesn't need to be done.",
                icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
              },
            ].map((item, i) => (
              <div class="flex gap-4 items-start">
                <div class="w-10 h-10 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center flex-shrink-0 mt-0.5" set:html={item.icon} />
                <div>
                  <h3 class="font-black text-brand-900 text-lg mb-1">{item.title}</h3>
                  <p class="text-gray-600 text-sm leading-relaxed">{item.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <PreFooterCTA
    overline="NEED SOMETHING HANDLED?"
    title="Call the Lone Ranger for Any Exterior Service"
    blurb="Roofing, fencing, painting, siding, garage doors — one contractor, one call. Serving Central Texas and DFW."
    bgImage="/pre-footer-background.webp"
  />

</MainLayout>
