---
import MainLayout from '../../layouts/MainLayout.astro';
import PreFooterCTA from '../../components/PreFooterCTA.astro';

const faqs = [
  {
    q: 'Is the roof inspection really free?',
    a: "Yes, roof inspections by Lone Ranger Roofing are completely free — no trip charge, no inspection fee, and no obligation to hire us afterward. Homeowners across Temple, Killeen, Harker Heights, Belton, and the greater DFW area can schedule a free roof inspection and get an honest assessment with zero strings attached.",
  },
  {
    q: 'How fast can you get out for an inspection?',
    a: "Lone Ranger Roofing offers same-day roof inspections across Central Texas and DFW — including Temple, Killeen, Harker Heights, Belton, Salado, and surrounding areas. Call in the morning and we can often have someone out the same day.",
  },
  {
    q: "What's the difference between the free inspection and the paid seller report?",
    a: "Lone Ranger Roofing's free roof inspection is available to any homeowner who wants to know the condition of their roof — it covers the full exterior and provides honest recommendations at no cost. The paid Seller Report is a separate service specifically for homeowners listing their home in Central Texas or DFW. It includes a detailed written report with high-resolution photos that can be shared directly with buyers, agents, and title companies to get ahead of any roofing issues before closing.",
  },
  {
    q: 'Do you inspect the attic too?',
    a: "Yes — Lone Ranger Roofing inspects the attic as part of the full roof inspection when access is available. Attic inspections help identify leaks, ventilation issues, and insulation problems that aren't visible from the roof surface. Most roofing companies in Central Texas skip this step entirely.",
  },
  {
    q: 'What happens if Lone Ranger Roofing finds damage during the inspection?',
    a: "If Lone Ranger Roofing finds damage during a roof inspection, we walk the homeowner through exactly what was found, what it means, and what their options are. If the damage is storm-related and potentially claimable, we explain the insurance process and can help document everything for a claim — serving homeowners across Temple, Killeen, Belton, and throughout Central Texas and DFW.",
  },
  {
    q: 'Do I need to be home during the roof inspection?',
    a: "Homeowners do not need to be present during a Lone Ranger Roofing inspection, though it helps to be available to walk through the findings in person immediately after. If you can't be home, our team will document everything and go over it by phone or at a time that works for you.",
  },
];

const whatIncluded = [
  {
    title: 'Exterior Roof Review',
    body: "We check shingles, flashing, gutters, and everything exposed to the elements. We're looking for signs of wear, storm damage, and anything that could become a problem down the road.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  },
  {
    title: 'Attic Inspection',
    body: "We get up in your attic to look for leaks, insulation gaps, ventilation issues, and anything structural that needs attention. Most roofers skip this step entirely.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>`,
  },
  {
    title: 'Ventilation & Drainage Check',
    body: "A roof that isn't breathing and draining properly deteriorates faster. We make sure yours is working the way it should.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3"/></svg>`,
  },
  {
    title: 'Full Exterior Assessment',
    body: "Beyond the roof itself, we look at your gutters, fascia, siding, and vents. If there's storm damage elsewhere on your home, we'll find it.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: 'Insurance Claim Guidance',
    body: "If we find damage, we'll tell you exactly what's claimable and walk you through next steps. You won't leave the inspection not knowing what to do.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
  },
  {
    title: 'Honest Recommendations',
    body: "No guessing games — just real advice on what to fix and what's perfectly fine. We're not going to manufacture a problem to sell you a replacement you don't need.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
  },
];

const whyCards = [
  {
    title: 'Same-Day Availability',
    body: 'Same-day inspections available across Bell County, Burnet County, and DFW — including Temple, Killeen, Harker Heights, Belton, Frisco, Plano, Arlington, and more.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'We Look at the Whole Picture',
    body: "Most roofers look at the roof. We inspect your full exterior because we work with insurance claims daily and know what gets missed.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: "Honest — Even When It's Not What You Want to Hear",
    body: "If your roof is fine, we'll tell you it's fine. We're not going to manufacture a problem to sell you a replacement you don't need.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
  },
  {
    title: 'Insurance Claim Expertise',
    body: "If there's damage worth claiming, we know how to document it properly so your claim reflects the full scope of what happened.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
  },
  {
    title: 'Veteran-Owned & Operated',
    body: "Built on the same standard Julio held in the Army. Show up, assess accurately, give a straight answer.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  },
  {
    title: 'Free — No Strings Attached',
    body: "The inspection costs you nothing. We earn your business by being straight with you, not by charging you to look at your own roof.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>`,
  },
