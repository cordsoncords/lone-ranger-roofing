const CITY_SLUGS: Record<string, string | null> = {
  'Temple': 'temple', 'Killeen': 'killeen', 'Harker Heights': 'harker-heights',
  'Belton': 'belton', 'Salado': 'salado', 'Nolanville': 'nolanville',
  'Little River-Academy': 'little-river-academy', 'Troy': 'troy',
  'Copperas Cove': 'copperas-cove', 'Gatesville': 'gatesville',
  'Waco': 'waco', 'Moody': 'moody',
  "Morgan's Point Resort": null, 'Bartlett': null, 'Holland': null,
  'Arlington': 'dfw', 'Plano': 'dfw', 'Irving': 'dfw', 'Garland': 'dfw',
  'Frisco': 'dfw', 'Denton': 'dfw', 'Richardson': 'dfw', 'McKinney': 'dfw',
  'Grapevine': 'dfw', 'Euless': 'dfw', 'Bedford': 'dfw', 'Southlake': 'dfw',
  'Burnet': 'burnet', 'surrounding areas': 'burnet',
};

const serviceAreas = {
  'Bell County': ['Temple', 'Killeen', 'Harker Heights', 'Belton', 'Salado', 'Nolanville', "Morgan's Point Resort", 'Little River-Academy', 'Troy', 'Bartlett', 'Holland', 'Copperas Cove', 'Gatesville', 'Moody'],
  'McLennan County': ['Waco'],
  'DFW Metroplex': ['Arlington', 'Plano', 'Irving', 'Garland', 'Frisco', 'Denton', 'Richardson', 'McKinney', 'Grapevine', 'Euless', 'Bedford', 'Southlake'],
  'Burnet County': ['Burnet', 'surrounding areas'],
};
---

<MainLayout
  title="Free Roof Inspection in Temple, Killeen & Central Texas | Lone Ranger Roofing"
  description="Lone Ranger Roofing offers free same-day roof inspections across Temple, Killeen, and Central Texas. We inspect your full exterior — not just the roof — so you never miss a claim you're owed."
  darkHero={true}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center bg-brand-900 overflow-hidden -mt-28">
    <div class="absolute inset-0">
      <img
        src="/storm-damage8.webp"
        alt="Free roof inspection — Temple and Killeen TX"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900 via-brand-900/85 to-brand-900/30"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 pt-20 pb-28">
      <div class="max-w-2xl">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4">Residential Roofing &rsaquo; Roof Inspection</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
          Free Roof Inspection in Temple, Killeen &amp; Central Texas
        </h1>
        <p class="text-xl text-gray-200 leading-relaxed mb-8">
          Most roofers look at the roof. We inspect the whole picture — boots on the roof, boots in the attic, full exterior.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center shadow-lg">
            Schedule Free Inspection
          </a>
          <a href="tel:+12543001413" class="border-2 border-white/50 hover:border-white text-white font-bold px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center hover:bg-white/10">
            Call (254) 300-1413
          </a>
        </div>

        <!-- Trust bar -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 mt-10">
          {[
            'Same-Day Availability',
            'Full Exterior Inspection',
            'Insurance Claim Guidance',
          ].map(t => (
            <div class="flex items-center gap-2 text-gray-300 text-sm">
              <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {t}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FULL EXTERIOR ===================== -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">

        <!-- Text side -->
        <div class="order-1">
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">Full Exterior Inspection</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-6">
            We Don't Just Inspect Your Roof. We Inspect Your Whole Exterior.
          </h2>
          <p class="text-gray-600 leading-relaxed mb-5">
            Here's something most roofing companies won't tell you: the Central Texas hailstorm that damaged your roof probably damaged more than your roof. Gutters, siding, fascia, vents, flashing — all of it takes a beating in a hailstorm or high-wind event.
          </p>
          <p class="text-gray-600 leading-relaxed mb-5">
            Most roofers only look at what they're being paid to fix. Lone Ranger Roofing inspects your full exterior because we work with insurance claims daily and we know what adjusters look for across the whole property. If there's damage you're entitled to claim, we'll find it — not just the part that's obvious from the ground.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Whether you're in Bell County, Burnet County, or anywhere across DFW — we inspect the full picture.
          </p>
        </div>

        <!-- Photo + checklist side -->
        <div class="relative order-2">
          <img
            src="/home-inspection.webp"
            alt="Lone Ranger Roofing full exterior inspection — Central Texas"
            class="w-full h-[480px] object-cover rounded-2xl shadow-xl"
          />
          <div class="absolute bottom-6 right-6 bg-brand-900 text-white rounded-xl p-5 max-w-[220px] shadow-xl border border-white/10" style="align-self: end;">
            <p class="text-gold-400 font-bold text-xs uppercase tracking-widest mb-3">What We Inspect</p>
            <ul class="space-y-1.5">
              {[
                'Roof shingles and decking',
                'Flashing and ridge caps',
                'Gutters and downspouts',
                'Soffit and fascia',
                'Attic ventilation and insulation',
                'Siding and exterior walls',
                'Vents and skylights',
              ].map(item => (
                <li class="flex items-start gap-2 text-brand-200 text-xs leading-snug">
                  <svg class="w-3 h-3 text-accent-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section class="relative py-24 bg-brand-900 text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/home-gallery1.webp"
        alt="Lone Ranger Roofing inspector on a Central Texas roof"
        class="w-full h-full object-cover opacity-15"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-900/95 via-brand-900/80 to-brand-900/95"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-14 items-center">

        <!-- Left: copy -->
        <div>
          <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-3">How It Works</p>
          <h2 class="text-3xl sm:text-4xl font-black mb-6">
            Same-Day Roof Inspections — Here's What to Expect
          </h2>
          <p class="text-brand-200 leading-relaxed">
            Scheduling a free inspection with Lone Ranger Roofing is straightforward. Here's how it works from your first call to your honest assessment. We serve homeowners across Temple, Killeen, Belton, Harker Heights, Nolanville, Salado, Burnet, Waco, and the entire DFW metro — including Frisco, Plano, Arlington, Richardson, Garland, and more.
          </p>
        </div>

        <!-- Right: interactive step accordion -->
        <div class="space-y-2" id="steps-list">
          {[
            { n: '01', title: 'Call or Schedule Online — Same-Day Availability', detail: 'Call (254) 300-1413 or schedule online. We offer same-day inspections across Central Texas and DFW — tell us where you are and we\'ll get someone out fast.' },
            { n: '02', title: 'We Inspect Your Full Roof and Exterior', detail: 'We get on the roof and go through everything — shingles, flashing, ridge caps, gutters, fascia, vents, and siding. No drive-by assessments.' },
            { n: '03', title: 'We Get in the Attic If Needed', detail: 'If there\'s reason to look — and often there is — we\'ll get in your attic to check for leaks, ventilation issues, and structural concerns that aren\'t visible from outside.' },
            { n: '04', title: 'Honest Assessment — What Needs Attention and What Doesn\'t', detail: 'We walk you through exactly what we found, what it means, and what your realistic options are. If your roof is fine, we tell you it\'s fine.' },
            { n: '05', title: 'Insurance Claim Guidance If Damage Is Found', detail: 'If we find storm damage that\'s claimable, we explain the insurance process, document everything properly, and help you get the full payout you\'re owed.' },
          ].map((step, i) => (
            <div class="step-item rounded-xl border overflow-hidden transition-all duration-200" data-active={i === 0 ? 'true' : 'false'}>
              <button class="step-item-btn w-full flex items-center gap-4 px-5 py-4 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <div class="step-circle w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center font-black text-xs transition-colors">
                  {step.n}
                </div>
                <span class="step-label font-bold text-sm flex-1 transition-colors">{step.title}</span>
                <svg class="step-arrow w-4 h-4 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class={`step-item-body px-5 pb-4 ${i === 0 ? '' : 'hidden'}`}>
                <p class="text-brand-200 text-sm leading-relaxed pl-[52px]">{step.detail}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== GALLERY STRIP ===================== -->
  <div class="grid grid-cols-3 md:grid-cols-6 h-48">
    {[
      '/home-gallery1.webp',
      '/home-gallery2.webp',
      '/home-gallery3.webp',
      '/home-gallery4.webp',
      '/home-gallery5.webp',
      '/home-gallery6.webp',
    ].map((src, i) => (
      <div class="relative overflow-hidden group">
        <img
          src={src}
          alt={`Roof inspection project ${i + 1} — Central Texas`}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-brand-900/30 group-hover:bg-brand-900/0 transition-colors duration-300"></div>
      </div>
    ))}
  </div>

  <!-- ===================== WHAT'S INCLUDED ===================== -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">

      <div class="flex flex-col lg:flex-row gap-10 items-center mb-14">
        <div class="lg:w-1/2">
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">What's Included</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-4">
            What's Included in Your Free Roof Inspection
          </h2>
          <p class="text-gray-600 leading-relaxed">
            No basic drive-by check here. We pull out all the stops — and if you're lucky, our very own shingle scent comes with it.
          </p>
