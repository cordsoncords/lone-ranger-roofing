---
import MainLayout from '../../layouts/MainLayout.astro';
import PreFooterCTA from '../../components/PreFooterCTA.astro';

const faqs = [
  {
    q: 'How long does a roof replacement take with Lone Ranger Roofing?',
    a: 'Most residential roof replacements completed by Lone Ranger Roofing are done in a single day — with a dedicated supervisor on-site the entire time. Homeowners in Temple, Killeen, Harker Heights, and Belton can typically expect their roof removed, replaced, and cleaned up before the crew leaves for the day.',
  },
  {
    q: 'How much does a roof replacement cost in Temple or Killeen?',
    a: 'Roof replacement costs in Temple, Killeen, and the greater Bell County area typically range from $8,000 to $18,000 depending on roof size, pitch, and materials. Lone Ranger Roofing provides free inspections and exact quotes — there\'s no guessing and no inflated estimates. Call (254) 300-1413 or schedule online to get a number based on your actual home.',
  },
  {
    q: "What's included in Lone Ranger Roofing's roof replacement service?",
    a: "A roof replacement from Lone Ranger Roofing includes full removal of the old roof, installation of new quality shingles, proper ventilation setup, flashing work, gutter inspection, and complete debris cleanup before the crew leaves. Homeowners across Central Texas and DFW get the same thorough process — no steps skipped, no shortcuts taken.",
  },
  {
    q: 'What warranty comes with a roof replacement from Lone Ranger Roofing?',
    a: "Lone Ranger Roofing warranties both the materials and the labor on every roof replacement. If the shingles fail or the installation develops problems, we cover it — not just the parts listed in fine print. Most roofing companies in Central Texas only warranty the materials. We warranty the work too.",
  },
  {
    q: 'Do I need a roof replacement or just a repair?',
    a: "Whether a roof needs replacement or just repair depends on age, extent of damage, and what the insurance adjuster documented. Lone Ranger Roofing offers free inspections across Temple, Killeen, Belton, and DFW — and we'll give you a straight answer on which option actually makes sense for your home. If repair will do the job, we'll say so.",
  },
  {
    q: 'How do I prepare for my roof replacement?',
    a: "Before a Lone Ranger Roofing crew arrives for a roof replacement, move vehicles out of the driveway, secure or bring in outdoor items that could blow around, and keep pets inside for the day. That's it — we handle everything else, including cleanup of all old roofing materials before we leave.",
  },
  {
    q: 'Can Lone Ranger Roofing help with my roof replacement insurance claim?',
    a: "Yes — Lone Ranger Roofing handles the full insurance claim process for roof replacements across Central Texas and DFW. We document the damage, work directly with your adjuster, and fight to make sure the claim reflects the full scope of what needs to be replaced. Homeowners in Temple, Killeen, and Bell County don't have to navigate the insurance process alone.",
  },
  {
    q: 'What materials does Lone Ranger Roofing use for roof replacements?',
    a: "Lone Ranger Roofing installs quality shingles backed by strong manufacturer warranties, using proper installation techniques that meet or exceed manufacturer specs. During your free inspection, we'll walk through the material options that fit your home and budget — whether you're in Temple, Killeen, or anywhere across Central Texas and DFW.",
  },
];

const warningSigns = [
  'Roof age over 20 years',
  'Hail damage across large areas',
  'Leaks in multiple locations',
  'Sagging or buckling shingles',
  'Missing or cracked shingles over 30% of the roof',
  'Granules washing off in gutters',
];

const whyCards = [
  {
    title: 'Dedicated On-Site Supervision',
    body: "A dedicated supervisor stays on your roof from the first shingle to the final inspection, making real-time decisions on your property instead of from a truck three jobs away. When problems come up, they get solved immediately by someone who actually knows your roof.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: 'Warranty on Materials AND Labor',
    body: "Most roofers warranty the shingles but not the installation — which is where real problems happen. Lone Ranger Roofing warranties both the materials and the work, so if the shingles fail, the flashing leaks, or anything was installed wrong, we come back and fix it.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    title: 'Insurance Claim Help',
    body: "Your insurance adjuster works for the insurance company, not for you. Lone Ranger Roofing handles the claim process for you — we document the damage, fight lowball estimates, and negotiate with adjusters to make sure you get what you're actually owed. We've handled hundreds of claims in Bell County and DFW.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
  },
  {
    title: 'Veteran-Owned & Operated',
    body: "Lone Ranger Roofing was founded by a veteran, which means attention to detail on every job and straight talk about what your roof actually needs. We show up, do the work right, and stand behind it.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  },
  {
    title: 'Done in One Day',
    body: "While other contractors stretch roof replacements across three days or more, your roof gets replaced in a single day. Your home stays protected, your yard stays yours, and you get your life back instead of living in a construction zone.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Local — Not Storm Chasers',
    body: "After every major hailstorm, out-of-state contractors flood Central Texas, take deposits, and disappear when the next storm hits somewhere else. Lone Ranger Roofing is rooted in Bell County and invested in the community we serve — not just chasing the next insurance claim.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`,
  },
];

const CITY_SLUGS: Record<string, string | null> = {
  'Temple': 'temple', 'Killeen': 'killeen', 'Harker Heights': 'harker-heights',
  'Belton': 'belton', 'Salado': 'salado', 'Nolanville': 'nolanville',
  'Little River-Academy': 'little-river-academy', 'Troy': 'troy',
  'Copperas Cove': 'copperas-cove', 'Gatesville': 'gatesville',
  'Waco': 'waco', 'Moody': 'moody',
  "Morgan's Point Resort": null, 'Bartlett': null, 'Holland': null,
  'Arlington': 'dfw', 'Plano': 'dfw', 'Irving': 'dfw', 'Garland': 'dfw',
  'Frisco': 'dfw', 'Denton': 'dfw', 'Richardson': 'dfw', 'McKinney': 'dfw',
  'Grapevine': 'dfw', 'Euless': 'dfw', 'Bedford': 'dfw', 'Southlake': 'dfw',
  'Burnet': 'burnet', 'surrounding areas': 'burnet',
};

const serviceAreas = {
  'Bell County': ['Temple', 'Killeen', 'Harker Heights', 'Belton', 'Salado', 'Nolanville', "Morgan's Point Resort", 'Little River-Academy', 'Troy', 'Bartlett', 'Holland', 'Copperas Cove', 'Gatesville', 'Moody'],
  'McLennan County': ['Waco'],
  'DFW Metroplex': ['Arlington', 'Plano', 'Irving', 'Garland', 'Frisco', 'Denton', 'Richardson', 'McKinney', 'Grapevine', 'Euless', 'Bedford', 'Southlake'],
  'Burnet County': ['Burnet', 'surrounding areas'],
};
---

<MainLayout
  title="Roof Replacement in Temple & Killeen, TX | One-Day Install | Lone Ranger Roofing"
  description="Veteran-owned roof replacement serving Temple, Killeen, Harker Heights, Belton & DFW. One-day completion. Strong material + labor warranty. Insurance claim help. Call (254) 300-1413."
  darkHero={true}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center bg-brand-900 overflow-hidden -mt-28">
    <div class="absolute inset-0">
      <img
        src="/home-roof-replacement.webp"
        alt="Roof replacement in progress — Temple and Killeen TX"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900 via-brand-900/85 to-brand-900/30"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 py-28">
      <div class="max-w-2xl">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4">Residential Roof Replacement Services</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
          Roof Replacement in Temple, Killeen &amp; Central Texas
        </h1>
        <p class="text-xl text-gray-200 leading-relaxed mb-8">
          Lone Ranger Roofing replaces residential roofs in one day with a warranty that covers both materials and labor.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center shadow-lg">
            Schedule Free Inspection
          </a>
          <a href="tel:+12543001413" class="border-2 border-white/50 hover:border-white text-white font-bold px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center hover:bg-white/10">
            Call (254) 300-1413
          </a>
        </div>

        <!-- Trust bar -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 mt-10">
          {[
            'One-Day Completion',
            'Material + Labor Warranty',
            'Insurance Claim Help',
          ].map(t => (
            <div class="flex items-center gap-2 text-gray-300 text-sm">
              <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {t}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== REPLACE OR REPAIR? ===================== -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">

        <!-- Photo side -->
        <div class="relative order-2 lg:order-1">
          <img
            src="/home-gallery2.webp"
            alt="Damaged roof shingles that need replacement — Bell County TX"
            class="w-full h-[480px] object-cover rounded-2xl shadow-xl"
          />
          <div class="absolute -bottom-5 -right-5 bg-accent-600 text-white rounded-2xl px-6 py-4 shadow-xl text-center">
            <p class="text-3xl font-black leading-none">20+</p>
            <p class="text-xs font-bold uppercase tracking-wide mt-1 text-red-100">Years = Replace</p>
          </div>
        </div>

        <!-- Text side -->
        <div class="order-1 lg:order-2">
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">REPLACE OR REPAIR?</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-6">
            Roof Replacement vs. Repair: When to Replace Your Roof in Temple &amp; Killeen
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Not every roof problem needs a full replacement. Sometimes a repair buys you time. But sometimes your roof is past the point of no return (and putting it off costs you thousands in water damage, energy loss, and structural problems).
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            If your roof is over 20 years old, has widespread damage from hail or wind, or is leaking in multiple spots, a roof repair won't cut it. You need a roof replacement.
          </p>

          <!-- Warning signs grid -->
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <p class="text-brand-900 font-black text-sm uppercase tracking-wide mb-4">Signs You Need Replacement — Not Repair</p>
            <div class="grid sm:grid-cols-2 gap-3">
              {warningSigns.map(sign => (
                <div class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-accent-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-gray-600 text-xs leading-snug">{sign}</span>
                </div>
              ))}
            </div>
            <p class="text-gray-500 text-xs mt-4">Seeing these? Call <a href="tel:+12543001413" class="font-bold text-accent-600">(254) 300-1413</a> for a free roof inspection. We'll tell you straight: repair or replace.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== ONE-DAY PROCESS ===================== -->
  <section class="relative py-24 bg-brand-900 text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/home-gallery1.webp"
        alt="Lone Ranger Roofing crew at work"
        class="w-full h-full object-cover opacity-15"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-900/95 via-brand-900/80 to-brand-900/95"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-14 items-center">

        <!-- Left: copy -->
        <div>
          <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-3">HOW IT WORKS</p>
          <h2 class="text-3xl sm:text-4xl font-black mb-6">
            One-Day Roof Replacement in Temple, Killeen &amp; Central Texas
          </h2>
          <p class="text-brand-200 leading-relaxed">
            Most roofing contractors take 3–5 days to replace a roof. Lone Ranger Roofing does it in one day — with a dedicated supervisor on-site the entire time. Your home is exposed less. Your life stays on schedule. Corners don't get cut.
          </p>
        </div>

        <!-- Right: interactive step accordion -->
        <div class="space-y-2" id="steps-list">
          {[
            { n: '01', title: 'Pre-Assessment & Measurements', detail: 'We measure your roof and document everything necessary before install day to prevent any surprises or delays.' },
            { n: '02', title: 'Full Crew Arrives Early Morning', detail: 'Your crew shows up bright and early to ensure we can complete your replacement in one day.' },
            { n: '03', title: 'Complete Tear-Off', detail: 'We always strip your roofing system down to the wood decking to ensure we are installing your new system on a solid foundation.' },
            { n: '04', title: 'New Roof Installation', detail: 'We install your new roofing system, making sure to follow manufacturer specs and proper building codes to ensure system longevity.' },
            { n: '05', title: 'Cleanup & Final Inspection', detail: 'Our team sweeps your property multiple times to ensure there is no debris or errant material present. We also use an industrial grade magnet to get any nails that our catch-all system didn\'t catch.' },
          ].map((step, i) => (
            <div class={`step-item rounded-xl border overflow-hidden transition-all duration-200 ${i === 0 ? 'border-gold-400 bg-white/12' : 'border-white/15 bg-white/5'}`} data-step-idx={i}>
              <button class="step-item-btn w-full flex items-center gap-4 px-5 py-4 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <div class={`w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center font-black text-xs transition-colors ${i === 0 ? 'bg-gold-400 text-brand-900' : 'bg-white/15 text-white'}`}>
                  {step.n}
                </div>
                <span class={`font-bold text-sm flex-1 transition-colors ${i === 0 ? 'text-white' : 'text-brand-200'}`}>{step.title}</span>
                <svg class={`w-4 h-4 flex-shrink-0 transition-transform duration-200 ${i === 0 ? 'text-gold-400 rotate-180' : 'text-white/40'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class={`step-item-body px-5 pb-4 ${i === 0 ? '' : 'hidden'}`}>
                <p class="text-brand-200 text-sm leading-relaxed pl-[52px]">{step.detail}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== GALLERY STRIP ===================== -->
  <div class="grid grid-cols-3 md:grid-cols-6 h-48">
    {[
      '/home-gallery1.webp',
      '/home-gallery2.webp',
      '/home-gallery3.webp',
      '/home-gallery4.webp',
      '/home-gallery5.webp',
      '/home-gallery6.webp',
    ].map((src, i) => (
      <div class="relative overflow-hidden group">
        <img
          src={src}
          alt={`Roof replacement project ${i + 1} — Central Texas`}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-brand-900/30 group-hover:bg-brand-900/0 transition-colors duration-300"></div>
      </div>
    ))}
  </div>

  <!-- ===================== MATERIALS & WARRANTY ===================== -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-14 items-center">

        <!-- Text side -->
        <div>
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">MATERIALS & WARRANTY</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-6">
            Strong Warranty on Materials AND Labor
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Most roofers warranty the materials but not the installation. That's the "cocktail umbrella" approach — it's there, but it's not great. Lone Ranger Roofing warranties both materials and labor to ensure you are always covered no matter what.
          </p>

          <div class="divide-y divide-gray-100 border border-gray-200 rounded-xl overflow-hidden mb-8" id="warranty-accordion">
            {[
              { label: 'Labor Warranty', sub: 'Covers installation defects — not just the materials. If a nail pops, flashing fails, or something was done wrong, we come back and fix it.' },
              { label: 'Manufacturer Warranty', sub: 'Every shingle we install carries a robust, product-backed manufacturer warranty to ensure you are always covered.' },
              { label: 'Wind & Hail Rated', sub: 'Our shingles are impact-rated for Texas weather — not just labeled that way. Built to take the hail, wind, and heat that Central Texas throws at a roof.' },
              { label: 'Algae Resistant', sub: 'Algae-resistant shingles keep your roof looking clean for years. No dark streaking, no premature wear from moisture and growth.' },
            ].map((item, i) => (
              <details class="group warranty-item" open={i === 0}>
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none hover:bg-gray-50 transition-colors">
                  <span class="font-bold text-brand-900 text-sm">{item.label}</span>
                  <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <p class="px-5 pb-4 text-gray-500 text-sm leading-relaxed">{item.sub}</p>
              </details>
            ))}
          </div>

          <a href="/contact" class="inline-flex items-center gap-2 bg-accent-600 hover:bg-accent-700 text-white font-black px-7 py-3.5 rounded-lg text-sm uppercase tracking-wide transition-colors">
            Schedule Free Inspection
          </a>
        </div>

        <!-- Photo -->
        <div class="relative">
          <img
            src="/cocktail.webp"
            alt="Quality shingles installed by Lone Ranger Roofing — Temple TX"
            class="w-full h-[500px] object-cover object-top rounded-2xl shadow-xl"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== INSURANCE CLAIM HELP ===================== -->
  <section class="relative py-24 bg-white overflow-hidden">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-14 items-center">

        <!-- Photo side -->
        <div class="relative">
          <img
            src="/home-storm-damage-repair.webp"
            alt="Storm damage roof inspection — Bell County Texas"
            class="w-full h-[500px] object-cover rounded-2xl shadow-xl"
          />
          <div class="absolute top-6 right-6 bg-brand-900 text-white rounded-xl p-5 max-w-[200px] shadow-xl border border-white/10">
            <svg class="w-6 h-6 text-gold-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
            </svg>
            <p class="font-black text-sm leading-tight">Adjusters work for the insurer — not for you</p>
          </div>
        </div>

        <!-- Text side -->
        <div>
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">INSURANCE CLAIM HELP</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-6">
            Insurance Claim Help: Why the Insurance Adjuster Doesn't Work for You
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            When your roof takes storm damage, your insurance company sends an adjuster. That adjuster works for the insurance company — not for you. Their job is to minimize the payout. If they miss damage or lowball the estimate, you're the one paying the difference.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Lone Ranger Roofing handles the claim negotiation for you. We've helped hundreds of Central Texas homeowners get what they're actually owed. Don't negotiate alone.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            {[
              { stat: '100%', label: 'Damage Documented' },
              { stat: 'We Fight', label: 'Low Estimates' },
              { stat: '100s', label: 'Claims Handled' },
