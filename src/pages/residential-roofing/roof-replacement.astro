<!-- Step accordion script -->
<script>
  document.querySelectorAll('.step-item-btn').forEach((btn, idx) => {
    btn.addEventListener('click', () => {
      const allItems = document.querySelectorAll('.step-item');
      allItems.forEach((item, i) => {
        const body = item.querySelector('.step-item-body');
        const circle = item.querySelector('.w-9.h-9');
        const label = item.querySelector('.font-bold.text-sm');
        const arrow = item.querySelector('svg');
        const isTarget = i === idx;
        item.classList.toggle('border-gold-400', isTarget);
        item.classList.toggle('bg-white\\/12', isTarget);
        item.classList.toggle('border-white\\/15', !isTarget);
        item.classList.toggle('bg-white\\/5', !isTarget);
        circle?.classList.toggle('bg-gold-400', isTarget);
        circle?.classList.toggle('text-brand-900', isTarget);
        circle?.classList.toggle('bg-white\\/15', !isTarget);
        circle?.classList.toggle('text-white', !isTarget);
        label?.classList.toggle('text-white', isTarget);
        label?.classList.toggle('text-brand-200', !isTarget);
        arrow?.classList.toggle('text-gold-400', isTarget);
        arrow?.classList.toggle('rotate-180', isTarget);
        arrow?.classList.toggle('text-white\\/40', !isTarget);
        body?.classList.toggle('hidden', !isTarget);
        btn.setAttribute('aria-expanded', isTarget ? 'true' : 'false');
      });
    });
  });
</script>

<!-- FAQ accordion script -->
<script>
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item.querySelector('.faq-answer');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = !answer.classList.contains('hidden');

      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

