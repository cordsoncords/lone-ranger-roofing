---
import MainLayout from '../../layouts/MainLayout.astro';
import PreFooterCTA from '../../components/PreFooterCTA.astro';

const faqs = [
  {
    q: 'What is a Roof Tune Up and what does it include?',
    a: 'A Roof Tune Up by Lone Ranger Roofing is a paid proactive maintenance service for homeowners across Temple, Killeen, Harker Heights, Belton, and Central Texas. It includes a detailed roof inspection, replacement of individual cracked or missing shingles, sealant application on flashings and penetrations, debris removal, and a full gutter check — all completed in a single visit.',
  },
  {
    q: 'Is the Roof Tune Up the same as the free inspection?',
    a: 'No. Lone Ranger Roofing\'s free roof inspection is an assessment to determine the condition of your roof and what it may need. The Roof Tune Up is a paid service that includes the inspection plus active maintenance work — shingle replacement, sealant application, debris removal, and gutter check. It\'s the difference between an assessment and actually doing the work.',
  },
  {
    q: 'When should I schedule a Roof Tune Up?',
    a: 'Homeowners in Temple, Killeen, and across Central Texas and DFW should consider a Roof Tune Up after any significant hailstorm or high-wind event, when their roof is 10 or more years old, before listing their home for sale, or if the roof hasn\'t been serviced in three or more years. Proactive maintenance is almost always less expensive than reactive repair.',
  },
  {
    q: 'How long does a Roof Tune Up take?',
    a: 'Most Roof Tune Up visits by Lone Ranger Roofing are completed in a few hours depending on the size and condition of the roof. We\'ll give you an accurate time estimate when you schedule.',
  },
  {
    q: 'Will the Roof Tune Up fix everything my roof needs?',
    a: 'The Roof Tune Up covers individual shingle replacements, sealant application, debris removal, and gutter checks. If we find damage that goes beyond tune up scope — such as widespread shingle failure, decking damage, or storm damage requiring a full repair or replacement — we\'ll document what we find and give you an honest assessment of what comes next. No pressure, just a straight answer.',
  },
  {
    q: 'Does a Roof Tune Up help before listing my home for sale?',
    a: 'Yes. A Lone Ranger Roofing Roof Tune Up is a smart move before listing a home in Temple, Killeen, Georgetown, or anywhere across Central Texas and DFW. It addresses minor issues before a buyer\'s inspector finds them, gives sellers documentation that the roof has been recently serviced, and can help prevent last-minute repair demands from slowing down or killing a deal.',
  },
];

const includedCards = [
  {
    title: 'Detailed Inspection',
    body: 'A full assessment of your roof\'s current condition — shingles, flashing, ridge caps, gutters, vents, and everything in between. We document what we find and walk you through it.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: 'Shingle Replacement',
    body: 'Any individual shingles that are cracked, missing, or lifting get replaced as part of the tune up. Small fixes now prevent big repairs later.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  },
  {
    title: 'Sealant Application',
    body: 'Flashings, pipe boots, vents, and other penetration points are the most common entry points for water. We reseal everything that needs it.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Debris Removal',
    body: 'Leaves, branches, and debris that accumulate on the roof and in gutters trap moisture and accelerate wear. We clear it all out.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM12.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM18.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/></svg>`,
  },
  {
    title: 'Gutter Check',
    body: 'We inspect your gutters for proper slope, secure attachment, and clear flow. Gutters that aren\'t draining correctly can back water up under your shingles.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
];

const whyCards = [
  {
    title: 'Proactive, Not Reactive',
    body: 'We find the small stuff before it becomes expensive. That\'s the whole point of a tune up.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'We Actually Get on the Roof',
    body: 'A lot of "inspections" are done from the ground with binoculars. We get up there, walk the roof, and look at everything up close.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  },
  {
    title: 'Five Services in One Visit',
    body: 'Inspection, shingle replacement, sealant, debris removal, and gutter check — all in one visit. Not four separate calls.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>`,
  },
  {
    title: 'Honest Assessment',
    body: 'If your roof is in good shape, we\'ll tell you. If there\'s something that needs attention beyond the tune up scope, we\'ll let you know what it is and what it costs — no pressure.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    title: 'Pre-Sale Ready',
    body: 'If you\'re getting ready to list your home in Temple, Killeen, Georgetown, or anywhere across Central Texas and DFW, a Roof Tune Up gives you confidence and documentation that the roof is in good condition.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
  },
  {
    title: 'Veteran-Owned & Operated',
    body: 'Same standard on every job. We\'re not here to upsell you on things your roof doesn\'t need.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  },
];

const CITY_SLUGS: Record<string, string | null> = {
  'Temple': 'temple', 'Killeen': 'killeen', 'Harker Heights': 'harker-heights',
  'Belton': 'belton', 'Salado': 'salado', 'Nolanville': 'nolanville',
  'Little River-Academy': 'little-river-academy', 'Troy': 'troy',
  'Copperas Cove': 'copperas-cove', 'Gatesville': 'gatesville',
  'Waco': 'waco', 'Moody': 'moody',
  "Morgan's Point Resort": null, 'Bartlett': null, 'Holland': null,
  'Arlington': 'dfw', 'Plano': 'dfw', 'Irving': 'dfw', 'Garland': 'dfw',
  'Frisco': 'dfw', 'Denton': 'dfw', 'Richardson': 'dfw', 'McKinney': 'dfw',
  'Grapevine': 'dfw', 'Euless': 'dfw', 'Bedford': 'dfw', 'Southlake': 'dfw',
  'Burnet': 'burnet', 'surrounding areas': 'burnet',
};

const serviceAreas = {
  'Bell County': ['Temple', 'Killeen', 'Harker Heights', 'Belton', 'Salado', 'Nolanville', "Morgan's Point Resort", 'Little River-Academy', 'Troy', 'Bartlett', 'Holland', 'Copperas Cove', 'Gatesville', 'Moody'],
  'McLennan County': ['Waco'],
  'DFW Metroplex': ['Arlington', 'Plano', 'Irving', 'Garland', 'Frisco', 'Denton', 'Richardson', 'McKinney', 'Grapevine', 'Euless', 'Bedford', 'Southlake'],
  'Burnet County': ['Burnet', 'surrounding areas'],
};
---

<MainLayout
  title="Roof Tune Up in Temple, Killeen & Central Texas | Lone Ranger Roofing"
  description="Lone Ranger Roofing's Roof Tune Up is a paid proactive maintenance service for homeowners across Temple, Killeen, and Central Texas. Don't gamble with your roof — tune it up."
  darkHero={true}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center bg-brand-900 overflow-hidden -mt-28">
    <div class="absolute inset-0">
      <img
        src="/shingle4.webp"
        alt="Roof tune up and maintenance in Temple and Killeen TX"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900 via-brand-900/85 to-brand-900/30"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 pt-40 pb-28">
      <div class="max-w-2xl">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4">Residential Roofing Services</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
          Roof Tune Up in Temple, Killeen &amp; Central Texas
        </h1>
        <p class="text-xl text-gray-200 leading-relaxed mb-8">
          Don't gamble with your roof. Most homeowners only call a roofer when something's visibly wrong — by then, a small problem has usually become an expensive one.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center shadow-lg">
            Schedule a Roof Tune Up
          </a>
          <a href="tel:+12543001413" class="border-2 border-white/50 hover:border-white text-white font-bold px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center hover:bg-white/10">
            Call (254) 300-1413
          </a>
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-3 mt-10">
          {[
            'Proactive Maintenance',
            'Multiple Services In One Visit',
            'Same-Day Availability',
          ].map(t => (
            <div class="flex items-center gap-2 text-gray-300 text-sm">
              <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {t}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== REACTIVE VS PROACTIVE ===================== -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">

        <!-- Text side -->
        <div>
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">REACTIVE VS. PROACTIVE</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-6">
            Most Homeowners Wait Too Long. Here's the Smarter Approach.
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Your roof is the first line of defense between your home and whatever Texas weather throws at it. But most people take a reactive approach — they only call a roofer when there's a leak, blown-off shingles, or obvious damage after a storm. By then, what started as a minor issue has usually worked its way into the decking, the attic, or the interior of the home.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Lone Ranger Roofing's Roof Tune Up is a PROACTIVE service. We get up there, find the small stuff before it becomes the big stuff, and fix it while it's still cheap. Homeowners in Temple, Killeen, Harker Heights, Belton, and across Central Texas and DFW use our Roof Tune Up service after severe weather events, when their roof is 10+ years old, or before listing their home for sale.
          </p>
        </div>

        <!-- Photo side with checklist overlay -->
        <div class="relative">
          <img
            src="/tune-up.webp"
            alt="Roof inspection and tune up — Temple and Killeen TX"
            class="w-full h-[480px] object-cover rounded-2xl shadow-xl"
          />
          <div class="absolute bottom-6 right-6 bg-brand-900 text-white rounded-xl px-5 py-4 shadow-xl max-w-[220px] border border-white/10">
            <p class="text-gold-400 font-black text-xs uppercase tracking-widest mb-3">Good Times to Schedule a Tune Up</p>
            <ul class="space-y-2">
              {[
                'After a hailstorm or high-wind event',
                'When your roof is 10+ years old',
                'Before listing your home for sale',
                'After a particularly harsh storm season',
                'If you haven\'t had your roof looked at in 3+ years',
              ].map(item => (
                <li class="flex items-start gap-2 text-gray-300 text-xs">
                  <svg class="w-3 h-3 text-gold-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== WHAT'S INCLUDED ===================== -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">WHAT'S INCLUDED</p>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-4">
          What's Included in a Lone Ranger Roof Tune Up
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">
          This isn't a basic visual check. We get on the roof, get in the attic if needed, and go through the whole system.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {includedCards.map(item => (
          <div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center" set:html={item.icon} />
            <h3 class="font-black text-brand-900 text-lg">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section class="relative py-24 bg-brand-900 text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/home-gallery1.webp"
        alt="Lone Ranger Roofing crew performing a roof tune up"
        class="w-full h-full object-cover opacity-15"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-900/95 via-brand-900/80 to-brand-900/95"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-14 items-center">

        <div>
          <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-3">HOW IT WORKS</p>
          <h2 class="text-3xl sm:text-4xl font-black mb-6">
            Scheduling a Roof Tune Up With Lone Ranger Is Simple
          </h2>
          <p class="text-brand-200 leading-relaxed">
            One call. One visit. Everything handled. Lone Ranger Roofing serves homeowners across Temple, Killeen, Harker Heights, Belton, and all of Central Texas and DFW.
          </p>
        </div>

        <div class="space-y-2" id="steps-list">
          {[
            { n: '01', title: 'Call or Schedule Online', detail: 'Reach us at (254) 300-1413 or schedule through our contact page. Same-day availability across Central Texas and DFW in most cases.' },
            { n: '02', title: 'We Get on the Roof and Inspect the Full System', detail: 'We physically get on your roof and inspect shingles, flashing, ridge caps, vents, gutters, and every potential problem area. No ground-level binocular inspections here.' },
            { n: '03', title: 'We Walk You Through What We Found', detail: 'We show you exactly what we found — photos, documentation, and a straight assessment of your roof\'s current condition. No upsell pressure, just the facts.' },
            { n: '04', title: 'We Complete the Tune Up — Shingles, Sealant, Debris, Gutter Check', detail: 'We replace cracked or missing shingles, reseal flashings and penetration points, clear all debris from the roof and gutters, and verify proper gutter drainage.' },
            { n: '05', title: 'You Get Peace of Mind That Your Roof Is Ready for Whatever\'s Next', detail: 'Your roof is serviced, documented, and ready for the next Central Texas storm season. If we found anything beyond the tune up scope, you have an honest written assessment of what comes next.' },
          ].map((step, i) => (
            <div class="step-item rounded-xl border overflow-hidden transition-all duration-200" data-active={i === 0 ? 'true' : 'false'}>
              <button class="step-item-btn w-full flex items-center gap-4 px-5 py-4 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <div class="step-circle w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center font-black text-xs transition-colors">
                  {step.n}
                </div>
                <span class="step-label font-bold text-sm flex-1 transition-colors">{step.title}</span>
                <svg class="step-arrow w-4 h-4 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class={`step-item-body px-5 pb-4 ${i === 0 ? '' : 'hidden'}`}>
                <p class="text-brand-200 text-sm leading-relaxed pl-[52px]">{step.detail}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== GALLERY STRIP ===================== -->
  <div class="grid grid-cols-3 md:grid-cols-6 h-48">
    {[
      '/home-gallery1.webp',
      '/home-gallery2.webp',
      '/home-gallery3.webp',
      '/home-gallery4.webp',
      '/home-gallery5.webp',
      '/home-gallery6.webp',
    ].map((src, i) => (
      <div class="relative overflow-hidden group">
        <img
          src={src}
          alt={`Roof tune up project ${i + 1} — Central Texas`}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-brand-900/30 group-hover:bg-brand-900/0 transition-colors duration-300"></div>
      </div>
    ))}
  </div>

  <!-- ===================== WHY LONE RANGER ===================== -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">

      <div class="flex flex-col lg:flex-row gap-10 items-center mb-14">
        <div class="lg:w-1/2">
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">WHY LONE RANGER ROOFING</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-4">
            Why Central Texas Homeowners Trust Lone Ranger for Roof Tune Ups
          </h2>
          <p class="text-gray-600 leading-relaxed">
            A tune up is only valuable if it's done by someone who actually gets on the roof, knows what to look for, and gives you a straight answer about what they find.
          </p>
        </div>
        <div class="lg:w-1/2 grid grid-cols-2 gap-3">
          <img src="/home-gallery4.webp" alt="Lone Ranger Roofing tune up in progress" class="w-full h-40 object-cover rounded-xl shadow-md" />
          <img src="/home-gallery5.webp" alt="Central Texas roof inspection crew" class="w-full h-40 object-cover rounded-xl shadow-md mt-6" />
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {whyCards.map(item => (
          <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-xl bg-accent-600/10 text-accent-600 flex items-center justify-center" set:html={item.icon} />
            <h3 class="font-black text-brand-900 text-lg">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/contact" class="inline-flex items-center gap-2 bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors shadow-lg">
          Schedule a Roof Tune Up
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICE AREAS ===================== -->
