---
import MainLayout from '../../layouts/MainLayout.astro';
import PreFooterCTA from '../../components/PreFooterCTA.astro';

const faqs = [
  {
    q: 'What should I do immediately after a storm damages my roof?',
    a: "Stay safe first — don't get on the roof yourself. Call Lone Ranger Roofing to schedule a free storm damage inspection as soon as possible. The faster the damage is documented, the stronger your insurance claim will be. Lone Ranger Roofing serves homeowners across Temple, Killeen, Belton, and the greater Central Texas and DFW area — and if there's active water intrusion, we can emergency tarp the affected area to prevent further interior damage while the claim is processed.",
  },
  {
    q: "Will my homeowner's insurance cover storm damage in Texas?",
    a: "Most standard homeowner's insurance policies in Texas cover storm damage caused by hail, wind, and rain. The challenge is that insurance adjusters sometimes classify storm damage as pre-existing wear to reduce the payout. Lone Ranger Roofing documents everything thoroughly — serving homeowners in Temple, Killeen, Harker Heights, and throughout Central Texas — so your claim accurately reflects what the storm actually did to your roof, not what the insurance company wanted to find.",
  },
  {
    q: 'How long do I have to file an insurance claim after a storm?',
    a: "Most Texas homeowner's insurance policies require storm damage claims to be filed within one year of the storm event, but some policies have shorter windows. Lone Ranger Roofing advises homeowners across Central Texas and DFW not to assume they have time — call after any significant weather event so the damage can be inspected and documented while it's fresh. Waiting can cost you the ability to file at all.",
  },
  {
    q: 'Do I need to be home when Lone Ranger Roofing inspects my roof?',
    a: "Homeowners don't need to be on the roof during a Lone Ranger Roofing storm damage inspection, but it helps to be available immediately after so we can walk you through the findings in person. If you can't be home, our team will document everything and go over it with you by phone or at a time that works — whether you're in Temple, Killeen, or anywhere across the DFW metro.",
  },
  {
    q: 'What if my insurance adjuster says the damage is minimal?',
    a: "That happens more than it should. Adjusters working for insurance companies are trained to minimize claims. If the assessment seems inaccurate, homeowners have the right to dispute it. Lone Ranger Roofing can meet the adjuster on-site, present independent documentation of the damage, and advocate for the full scope of what the storm actually caused — across Central Texas, Bell County, and DFW.",
  },
  {
    q: 'Do you handle both the insurance claim and the actual repair?',
    a: "Yes — that's the whole point. Lone Ranger Roofing doesn't just fix roofs and hand you a bill. We walk homeowners in Temple, Killeen, Belton, and throughout Central Texas through the entire storm damage claim process: inspecting the damage, documenting it properly, communicating with the insurance company, and completing the repair or replacement once the claim is approved. One call handles all of it.",
  },
];

const damageTypes = [
  {
    title: 'Hail Damage',
    body: 'Hail can destroy a roof without it being obvious from the ground. Cracked shingles, dented flashing, and granule loss all add up. We document every hit.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/></svg>`,
  },
  {
    title: 'Wind Damage',
    body: 'High winds lift shingles, tear off ridge caps, and create entry points for water. What looks minor from the street can be a serious leak waiting to happen.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0119.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 004.5 10.5a7.464 7.464 0 01-1.15 3.993m1.989 3.559A11.209 11.209 0 008.25 10.5a3.75 3.75 0 117.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 01-3.6 9.75m6.633-4.596a18.666 18.666 0 01-2.485 5.33"/></svg>`,
  },
  {
    title: 'Heavy Rain & Leaks',
    body: 'Water finds every weakness. If your roof has been compromised, heavy rain will expose it. We find the source and fix it — not just the symptom.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>`,
  },
  {
    title: 'Storm Debris Impact',
    body: 'Falling branches and flying debris can punch through shingles or crack decking. We assess the full impact, not just the visible damage.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>`,
  },
  {
    title: 'Emergency Tarping',
    body: 'If your roof needs immediate protection before repairs can begin, we\'ll tarp it fast to prevent further water damage inside your home.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
];

const whyCards = [
  {
    title: 'We Specialize in Insurance Claims',
    body: "This isn't something we help with on the side. Storm damage claims are a core part of what we do. We know the process and we fight for the full payout you're owed.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
  },
  {
    title: 'Fast Response',
    body: "We know storms don't wait for a good time. We move quickly to inspect, document, and protect your home before more damage sets in.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Emergency Tarping Available',
    body: "If your roof needs immediate protection, we'll get it covered fast.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  },
  {
    title: 'Veteran-Owned & Operated',
    body: "Julio built this company on the same standard he held in the Army. Show up. Do the job right. Don't leave until it's done.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  },
  {
    title: 'Warranty on Materials AND Labor',
    body: "Every repair and replacement is backed by a warranty on both. If something fails, we stand behind it.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    title: "Local — We're Here After the Storm Chasers Leave",
    body: "Out-of-state storm chasers flood Central Texas after every major weather event. They'll be gone before your warranty matters. We live and work here.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`,
  },
];

const CITY_SLUGS: Record<string, string | null> = {
  'Temple': 'temple', 'Killeen': 'killeen', 'Harker Heights': 'harker-heights',
  'Belton': 'belton', 'Salado': 'salado', 'Nolanville': 'nolanville',
  'Little River-Academy': 'little-river-academy', 'Troy': 'troy',
  'Copperas Cove': 'copperas-cove', 'Gatesville': 'gatesville',
  'Waco': 'waco', 'Moody': 'moody',
  "Morgan's Point Resort": null, 'Bartlett': null, 'Holland': null,
  'Arlington': 'dfw', 'Plano': 'dfw', 'Irving': 'dfw', 'Garland': 'dfw',
  'Frisco': 'dfw', 'Denton': 'dfw', 'Richardson': 'dfw', 'McKinney': 'dfw',
  'Grapevine': 'dfw', 'Euless': 'dfw', 'Bedford': 'dfw', 'Southlake': 'dfw',
  'Burnet': 'burnet', 'surrounding areas': 'burnet',
};

const serviceAreas = {
  'Bell County': ['Temple', 'Killeen', 'Harker Heights', 'Belton', 'Salado', 'Nolanville', "Morgan's Point Resort", 'Little River-Academy', 'Troy', 'Bartlett', 'Holland', 'Copperas Cove', 'Gatesville', 'Moody'],
  'McLennan County': ['Waco'],
  'DFW Metroplex': ['Arlington', 'Plano', 'Irving', 'Garland', 'Frisco', 'Denton', 'Richardson', 'McKinney', 'Grapevine', 'Euless', 'Bedford', 'Southlake'],
