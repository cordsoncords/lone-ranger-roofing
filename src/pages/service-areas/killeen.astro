---
import MainLayout from '../../layouts/MainLayout.astro';
import PreFooterCTA from '../../components/PreFooterCTA.astro';

const city = 'Killeen';
const county = 'Bell County';
const state = 'TX';

const services = [
  { title: 'Roof Replacement', href: '/residential-roofing/roof-replacement', body: 'Full tear-off and replacement with IKO architectural shingles or metal. Most residential roofs in Killeen completed in one day.' },
  { title: 'Storm Damage Repair', href: '/residential-roofing/storm-damage-repair', body: 'Hail and wind damage documentation, insurance claim assistance, and full repair or replacement for Killeen and Fort Hood area homes.' },
  { title: 'Roof Inspection', href: '/residential-roofing/roof-inspection', body: 'Free roof inspections for Killeen homeowners — before buying, after a storm, or anytime you\'re not sure what you\'re dealing with up there.' },
  { title: 'Roof Tune Up', href: '/residential-roofing/roof-tune-up', body: 'Minor repairs, sealant, and gutter check to extend your roof\'s life. Catch problems early and avoid a full replacement before it\'s time.' },
  { title: 'Metal Roofing', href: '/residential-roofing/metal-roofing', body: '40+ year lifespan with virtually no maintenance. Handles Central Texas heat, hail, and high winds season after season.' },
  { title: 'Gutter Installation', href: '/residential-roofing/gutter-installation', body: 'Seamless gutters sized and pitched for your roofline. Protects your foundation, fascia, and exterior from water intrusion and runoff damage.' },
];

const nearbyAreas = ['Harker Heights', 'Copperas Cove', 'Nolanville', 'Belton', 'Temple', 'Salado', 'Fort Hood'];

const faqs = [
  {
    q: 'Does Lone Ranger Roofing serve military families in Killeen and the Fort Hood area?',
    a: "Yes. Lone Ranger Roofing serves military families in Killeen and throughout the Fort Hood area. Our founder Julio Rojas is a U.S. Army Ranger veteran — we understand the schedules and timelines military families deal with. We're responsive, we communicate clearly, and we do most residential roof replacements in Killeen in a single day so your life stays on track.",
  },
  {
    q: 'How quickly can Lone Ranger Roofing respond to a roofing emergency in Killeen?',
    a: 'Lone Ranger Roofing responds same-day to roofing emergencies in Killeen and across Bell County. Call (254) 300-1413 — we prioritize active leaks and storm-related damage. We\'ll get someone to your Killeen property quickly to assess, tarp if needed, and walk you through next steps.',
  },
  {
    q: 'Does Lone Ranger Roofing help with insurance claims for storm damage in Killeen?',
    a: "Yes. When hail or wind damages a roof in Killeen, Lone Ranger Roofing documents the damage, provides a detailed inspection report, and works directly with your insurance company to ensure the full scope is covered. We've helped many Killeen homeowners navigate the claim process and avoid leaving money on the table.",
  },
  {
    q: 'How much does a roof replacement cost in Killeen, TX?',
    a: 'Roof replacement costs in Killeen typically range from $8,000–$18,000+ for a residential home depending on roof size, pitch, material, and complexity. Lone Ranger Roofing provides free estimates for Killeen homeowners with no pressure and no hidden charges. If your roof qualifies under an insurance claim, your out-of-pocket is often just the deductible.',
  },
  {
    q: 'How long does a roof replacement take in Killeen?',
    a: "Most residential roof replacements by Lone Ranger Roofing in Killeen are completed in one day. We run one crew per project from start to finish — not rotating teams — which keeps the timeline tight and the quality consistent. Larger or more complex roofs may take two days, but we'll tell you upfront.",
  },
  {
    q: 'Is Lone Ranger Roofing insured in Texas?',
    a: 'Yes. Lone Ranger Roofing is insured in the state of Texas. We carry general liability and workers\' comp coverage on every job in Killeen and across our full service area. Ask us for proof of insurance — any reputable roofing contractor in Killeen should hand that over without hesitation.',
  },
];
---

<MainLayout
  title={`Roofing in ${city}, TX | Lone Ranger Roofing | (254) 300-1413`}
  description={`Lone Ranger Roofing serves ${city}, TX with roof replacements, storm damage repair, and inspections. Veteran-owned, one-day completions, material and labor warranty. Free estimate. (254) 300-1413.`}
  darkHero={true}
>

  <!-- ===================== HERO ===================== -->
  <section class="relative min-h-[65vh] flex items-center bg-brand-900 overflow-hidden -mt-28">
    <div class="absolute inset-0">
      <img
        src="/killeen1.webp"
        alt={`Roofing contractor in ${city}, TX`}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-900 via-brand-900/85 to-brand-900/40"></div>
    </div>

    <div class="relative z-10 container mx-auto px-4 pt-20 pb-28">
      <div class="max-w-2xl">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-4">Service Area — {county}</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
          Roofing in {city}, TX
        </h1>
        <p class="text-xl text-gray-200 leading-relaxed mb-8">
          Veteran-owned. One-day completions. Warranties on both materials and labor. Lone Ranger Roofing is the roofing contractor {city} calls.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-black px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center shadow-lg">
            Get a Free Estimate
          </a>
          <a href="tel:+12543001413" class="border-2 border-white/50 hover:border-white text-white font-bold px-8 py-4 rounded-lg text-sm uppercase tracking-wide transition-colors text-center hover:bg-white/10">
            Call (254) 300-1413
          </a>
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-3 mt-10">
          {['Same-Day Response', 'One-Day Completions', 'Military Family Friendly'].map(t => (
            <div class="flex items-center gap-2 text-gray-300 text-sm">
              <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {t}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== INTRO ===================== -->
  <!-- Photo 1 of 3 (non-hero): founder photo, right column -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <div>
          <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">YOUR LOCAL KILLEEN ROOFER</p>
          <h2 class="text-3xl sm:text-4xl font-black text-brand-900 mb-6">
            Killeen Is One of Our Home Markets. We're Not Passing Through.
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Killeen homeowners — including a large number of military families in the Fort Hood area — need a roofing contractor who's going to show up when they say they will, complete the job without dragging it out, and still be reachable after the invoice is paid.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            Lone Ranger Roofing founder Julio Rojas is a U.S. Army Ranger veteran. He built this company around the standard he held in service: show up, do the work right, be accountable for it. Every Killeen roof replacement runs one crew, start to finish — no rotating teams, no delays, no excuses.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Most residential roof replacements in Killeen are done in a single day. We use IKO architectural shingles and back every installation with both a manufacturer material warranty and our own labor warranty. When Central Texas hail hits — and it will — you'll know exactly who to call.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="bg-accent-600 hover:bg-accent-700 text-white font-black px-6 py-3 rounded-lg text-sm uppercase tracking-wide transition-colors text-center">
              Free Killeen Estimate
            </a>
            <a href="tel:+12543001413" class="border border-brand-900 text-brand-900 hover:bg-brand-900 hover:text-white font-bold px-6 py-3 rounded-lg text-sm uppercase tracking-wide transition-colors text-center">
              (254) 300-1413
            </a>
          </div>
        </div>

        <div class="relative">
          <img
            src="/killeen2.webp"
            alt="Julio Rojas — Owner, Lone Ranger Roofing, U.S. Army Ranger veteran"
            class="w-full h-[480px] object-cover object-top rounded-2xl shadow-xl"
          />        </div>

      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="bg-gray-50">
    <!-- Photo header with dark overlay -->
    <div class="relative py-16 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/home-gallery3.webp"
          alt="Roofing services in Killeen, TX"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-brand-900/80"></div>
      </div>
      <div class="relative z-10 container mx-auto px-4 max-w-6xl text-center">
        <p class="text-gold-400 font-bold text-sm uppercase tracking-widest mb-3">SERVICES IN KILLEEN</p>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">
          Roofing Services Available in {city}, TX
        </h2>
        <p class="text-gray-200 max-w-2xl mx-auto">
          From full roof replacements to tune-ups and storm damage repair, Lone Ranger Roofing handles it all for Killeen homeowners and commercial property owners.
        </p>
      </div>
    </div>

    <!-- Cards + Nearby -->
    <div class="py-14 container mx-auto px-4 max-w-6xl">
      <!-- 6-card uniform grid: 3 columns × 2 rows on desktop -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {services.map(svc => (
          <a href={svc.href} class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 hover:border-accent-600/30 hover:shadow-md transition-all flex flex-col gap-3 group">
            <h3 class="font-black text-brand-900 text-lg group-hover:text-accent-600 transition-colors">{svc.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-1">{svc.body}</p>
            <span class="text-accent-600 font-bold text-xs uppercase tracking-wide flex items-center gap-1">
              Learn More
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Also Nearby — dark card -->
      <div class="bg-brand-900 rounded-2xl px-8 py-8 text-center">
        <svg class="w-6 h-6 text-gold-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <h3 class="font-black text-white text-base mb-2">Also Serving the Areas Around Killeen</h3>
        <p class="text-brand-200 text-sm leading-relaxed mb-4 max-w-xl mx-auto">
          We also serve the areas around Killeen — Harker Heights, Copperas Cove, Nolanville, Belton, Temple, Salado, and Fort Hood. If you're just outside Killeen, we've got you covered.
        </p>
        <div class="flex flex-wrap gap-2 justify-center">
          {nearbyAreas.map(area => (
            <span class="border border-white/30 text-white text-xs font-semibold px-3 py-1.5 rounded-full hover:border-white/60 transition-colors">
              {area}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="text-center mb-12">
        <p class="text-accent-600 font-bold text-sm uppercase tracking-widest mb-3">COMMON QUESTIONS</p>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-900">
          Roofing in {city}, TX — Frequently Asked Questions
        </h2>
      </div>

      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden faq-item">
            <button
              class="w-full text-left px-6 py-5 flex justify-between items-center gap-4 faq-trigger"
              aria-expanded="false"
            >
              <span class="font-bold text-brand-900 text-sm leading-snug">{faq.q}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform faq-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-5">
              <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PreFooterCTA
    overline={`KILLEEN'S ROOFING CONTRACTOR`}
    title={`Get a Free Roofing Estimate in ${city}, TX`}
    blurb="Lone Ranger Roofing serves Killeen homeowners and commercial properties with fast response, one-day completions, and full material and labor warranties."
    bgImage="/pre-footer-background.webp"
  />

</MainLayout>

<script>
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = !answer?.classList.contains('hidden');

      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Does Lone Ranger Roofing serve military families in Killeen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Lone Ranger Roofing serves military families in Killeen and the Fort Hood area. Our founder is a U.S. Army Ranger veteran. We do most Killeen roof replacements in a single day to minimize disruption." }
    },
    {
      "@type": "Question",
      "name": "How quickly can Lone Ranger Roofing respond to a roofing emergency in Killeen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Same-day. Call (254) 300-1413. We prioritize active leaks and storm damage in Killeen and across Bell County." }
    },
    {
      "@type": "Question",
      "name": "Does Lone Ranger Roofing help with insurance claims for storm damage in Killeen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We document damage, provide inspection reports, and work directly with your insurance company to ensure the full scope of storm damage repairs is covered for Killeen homeowners." }
    },
    {
      "@type": "Question",
      "name": "How much does a roof replacement cost in Killeen, TX?",
      "acceptedAnswer": { "@type": "Answer", "text": "Typically $8,000–$18,000+ depending on size, pitch, and material. Lone Ranger Roofing provides free estimates for Killeen homeowners. If you have an insurance claim, out-of-pocket is often just the deductible." }
    },
    {
      "@type": "Question",
      "name": "How long does a roof replacement take in Killeen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most residential roof replacements by Lone Ranger Roofing in Killeen are completed in one day." }
    },
    {
      "@type": "Question",
      "name": "Is Lone Ranger Roofing insured in Texas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Insured in Texas with general liability and workers' comp on every Killeen job. We'll provide proof of insurance without hesitation." }
    }
  ]
}
</script>
