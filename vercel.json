{
  "headers": [
    {
      "source": "/(.+\\.(?:webp|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|otf))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.+\\.(?:js|css))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
